Panels:
  - Class: rviz_common/Displays
    Help Height: 138
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Scene Graph1/Topic1
        - /Omniplanner Viz1/Topic1
        - /AWCDPriorMesh1/Topic1
        - /GlobalPriorMesh1/Topic1
      Splitter Ratio: 0.5
    Tree Height: 1106
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Expanded:
      - /2D Goal Pose1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz_common/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: ""
  - Class: nlu_interface_rviz::InstructionPanel
    Name: InstructionPanel
  - Class: dsg_analyzer_rviz::DsgStatsPanel
    Name: DsgStatsPanel
  - Class: nlu_interface_rviz::ManipulationApprovalPanel
    Name: ManipulationApprovalPanel
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.10000000149011612
      Cell Size: 1
      Class: rviz_default_plugins/Grid
      Color: 160; 160; 164
      Enabled: true
      Line Style:
        Line Width: 0.029999999329447746
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 2000
      Reference Frame: <Fixed Frame>
      Value: true
    - Class: rviz_default_plugins/Axes
      Enabled: true
      Length: 2
      Name: Axes
      Radius: 0.20000000298023224
      Reference Frame: <Fixed Frame>
      Value: true
    - Alpha: 1
      Class: rviz_default_plugins/RobotModel
      Collision Enabled: false
      Description File: ""
      Description Source: Topic
      Description Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: robot_description
      Enabled: true
      Links:
        All Links Enabled: true
        Expand Joint Details: false
        Expand Link Details: false
        Expand Tree: false
        Link Tree Style: Links in Alphabetic Order
      Mass Properties:
        Inertia: false
        Mass: false
      Name: RobotModel
      TF Prefix: ""
      Update Interval: 0
      Value: true
      Visual Enabled: true
    - Class: rviz_default_plugins/TF
      Enabled: true
      Filter (blacklist): ""
      Filter (whitelist): ""
      Frame Timeout: 10000
      Frames:
        All Enabled: false
        base_link:
          Value: false
        imu_link:
          Value: false
        map:
          Value: true
        os_imu:
          Value: false
        pascal/base_link:
          Value: true
        pascal/dlio/lidar_sensor:
          Value: false
        pascal/dlio/microstrain_imu:
          Value: false
        pascal/lidar:
          Value: false
        pascal/lidar_sensor:
          Value: false
        pascal/microstrain_imu:
          Value: false
        pascal/odom:
          Value: true
        pascal_zed_camera_center:
          Value: false
        pascal_zed_camera_link:
          Value: false
        pascal_zed_left_camera_frame:
          Value: false
        pascal_zed_left_camera_optical_frame:
          Value: false
        pascal_zed_right_camera_frame:
          Value: false
        pascal_zed_right_camera_optical_frame:
          Value: false
        prior_map_frame:
          Value: true
      Marker Scale: 10
      Name: TF
      Show Arrows: true
      Show Axes: true
      Show Names: true
      Tree:
        map:
          pascal/odom:
            pascal/base_link:
              pascal/dlio/lidar_sensor:
                {}
              pascal/dlio/microstrain_imu:
                {}
              pascal/lidar_sensor:
                os_imu:
                  {}
                pascal/lidar:
                  {}
              pascal/microstrain_imu:
                {}
              pascal_zed_camera_link:
                pascal_zed_camera_center:
                  pascal_zed_left_camera_frame:
                    pascal_zed_left_camera_optical_frame:
                      {}
                  pascal_zed_right_camera_frame:
                    pascal_zed_right_camera_optical_frame:
                      {}
            prior_map_frame:
              {}
      Update Interval: 0
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: false
      Name: Scene Graph
      Namespaces:
        {}
      Topic:
        Depth: 5
        Durability Policy: Transient Local
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /pascal/hydra_multi_visualizer/graph
      Value: false
    - Class: kimera_pgmo_rviz/MeshDisplay
      Cull Backfaces: true
      Enable Lighting: false
      Enabled: true
      Name: Mesh
      Toggle Visibility All: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: hydra/backend/dsg_mesh
      Value: true
      Visible:
        0: true
        Value: true
    - Class: rviz_default_plugins/Image
      Enabled: true
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: RGB
      Normalize Range: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /hamilton/hamilton_zed/rgb/image_rect_color
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Omniplanner Viz
      Namespaces:
        {}
