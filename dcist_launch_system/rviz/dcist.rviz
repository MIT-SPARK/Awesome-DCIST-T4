      Name: ChangedObjectBbox
      Namespaces:
        "": true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /pascal/change_detector_visualizer/changed_object_bounding_boxes
      Value: true
    - Class: rviz_default_plugins/Marker
      Enabled: true
