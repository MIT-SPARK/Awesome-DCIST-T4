# ---------------------------------------------------------------------------
# CLI mode (click subcommands)
# ---------------------------------------------------------------------------


class FleetContext:
    def __init__(self, network, topology_path, output_root):
        self.topology = load_topology(topology_path)
        self.output_root = output_root
        self.network = network or detect_network(self.topology)
        if not self.network:
            click.secho(
                "Could not auto-detect network. Use --network to specify.", fg="red"
            )
            sys.exit(1)

    def machines(self, roles=None, names=None):
        return resolve_machines(self.topology, self.network, roles=roles, names=names)


@click.group(invoke_without_command=True)
@click.option(
    "--network",
    "-n",
    type=click.Choice(["mit_wifi", "penn_wifi", "silvus"]),
    default=None,
    help="Network to use (auto-detected if omitted)",
)
@click.option("--topology", "-t", type=click.Path(exists=True), default=None)
@click.option("--output-root", "-o", default="~/adt4_output", help="Remote output root")
@click.pass_context
def cli(ctx, network, topology, output_root):
    """ADT4 Fleet Management Tool. Run without subcommand for interactive TUI."""
    ctx.ensure_object(dict)
    ctx.obj["network"] = network
    ctx.obj["topology"] = topology
    ctx.obj["output_root"] = output_root
    if ctx.invoked_subcommand is None:
        _launch_tui(network, topology, output_root)


# --- status ---


@cli.command()
@click.option("--role", type=click.Choice(["robot", "base_station"]), default=None)
@click.pass_context
def status(ctx, role):
    """Check connectivity to all fleet machines (ping + SSH)."""
    fc = FleetContext(
        ctx.obj["network"], ctx.obj["topology"], ctx.obj["output_root"]
    )
    roles = [role] if role else None
    machines = fc.machines(roles=roles)
    if not machines:
        click.secho("No machines found on this network.", fg="yellow")
        return

    click.secho(f"Network: {fc.network}  ({len(machines)} machines)\nChecking connectivity...", fg="cyan")
    reachable, unreachable = filter_reachable(machines)

    all_checked = reachable + unreachable
    all_checked.sort(key=lambda m: m["name"])

    table = Table(title="Fleet Status")
    table.add_column("Machine", style="bold")
    table.add_column("Role")
    table.add_column("Platform")
    table.add_column("IP")
    table.add_column("Ping")
    table.add_column("SSH")
    table.add_column("Status")

    for m in all_checked:
        ping_str = "[green]OK[/]" if m.get("ping") else "[red]FAIL[/]"
        ssh_str = "[green]OK[/]" if m.get("ssh") else "[red]FAIL[/]"
        if m.get("online"):
            status_str = "[bold green]ONLINE[/]"
        elif m.get("ping"):
            status_str = "[yellow]NO SSH[/]"
        else:
            status_str = "[red]OFFLINE[/]"
        table.add_row(
            m["name"], m["role"], m["platform_id"] or "---",
            m["ip"], ping_str, ssh_str, status_str,
        )

    console.print(table)
    n_online = len(reachable)
    n_total = len(all_checked)
    console.print(f"\n[bold]{n_online}/{n_total} machines online[/]")


# --- maps ---


@cli.command()
@click.option("--machine", "-m", multiple=True, help="Filter to specific machines")
@click.option("--detail", is_flag=True, help="Show subdirs and sizes")
@click.pass_context
def maps(ctx, machine, detail):
    """List experiments on fleet machines."""
    fc = FleetContext(
        ctx.obj["network"], ctx.obj["topology"], ctx.obj["output_root"]
    )
    names = list(machine) if machine else None
    machines = fc.machines(names=names)

    def fetch(m):
        return list_remote_experiments(m["user"], m["ip"], fc.output_root)

    results = run_parallel(fetch, machines)

    table = Table(title="Experiments")
    table.add_column("Machine", style="bold")
    table.add_column("Experiment")
    if detail:
        table.add_column("Subdirs")
        table.add_column("Size")

    for m, exps in sorted(results, key=lambda x: x[0]["name"]):
        if isinstance(exps, Exception):
            row = [m["name"], f"[red]Error: {exps}[/]"]
            if detail:
                row += ["", ""]
            table.add_row(*row)
            continue
        if not exps:
            row = [m["name"], "[dim]no experiments[/]"]
            if detail:
                row += ["", ""]
            table.add_row(*row)
            continue
        for i, exp in enumerate(sorted(exps, key=lambda e: e["name"])):
            mname = m["name"] if i == 0 else ""
            row = [mname, exp["name"]]
            if detail:
                row += [", ".join(exp["subdirs"]), exp["size"]]
            table.add_row(*row)

    console.print(table)


# --- transfer ---


@cli.command()
@click.option("--from", "src_machine", required=True, help="Source machine name")
@click.option("--experiment", "-e", required=True, help="Experiment directory name")
@click.option("--as", "dest_name", default=None, help="Rename experiment on destination")
@click.option("--to", "dst_machines", multiple=True, help="Dest machines (default: all other robots)")
@click.option("--subdir", default=None, help="Only transfer a specific subdir (e.g. hydra, roman)")
@click.option("--include-bags", is_flag=True, help="Include recorded_data/ (rosbags). Excluded by default.")
@click.option("--delete", is_flag=True, help="Delete extraneous files on destination")
@click.option("--relay", is_flag=True, help="Force relay through operator machine")
@click.pass_context
def transfer(ctx, src_machine, experiment, dest_name, dst_machines, subdir, include_bags, delete, relay):
    """Transfer an experiment from one machine to others. Excludes rosbags by default."""
    fc = FleetContext(
        ctx.obj["network"], ctx.obj["topology"], ctx.obj["output_root"]
    )
    all_machines = fc.machines()
    src = next((m for m in all_machines if m["name"] == src_machine), None)
    if not src:
        click.secho(f"Source machine '{src_machine}' not found on network.", fg="red")
        return

    src_status = check_machine(src)
    if not src_status["online"]:
        click.secho(f"Source machine '{src_machine}' ({src['ip']}) is not reachable (ping={src_status['ping']}, ssh={src_status['ssh']}).", fg="red")
        return

    if dst_machines:
        dests = [m for m in all_machines if m["name"] in dst_machines]
    else:
        dests = [m for m in all_machines if m["name"] != src_machine]

    if not dests:
        click.secho("No destination machines found.", fg="yellow")
        return

    click.echo("Checking destination reachability (ping + SSH)...")
    reachable, unreachable = filter_reachable(dests)
    for dst in unreachable:
        reason = "offline" if not dst.get("ping") else "no SSH"
        click.secho(f"  Skipping {dst['name']} ({dst['ip']}) — {reason}", fg="yellow")
    if not reachable:
        click.secho("No reachable destinations.", fg="red")
        return

    dest_name = dest_name if dest_name is not None else f"prior_{experiment}"
    path_suffix = f"/{subdir}" if subdir else ""
    src_path = f"{fc.output_root}/{experiment}{path_suffix}"

    label = f"{src_machine}:{src_path}"
    if dest_name != experiment:
        label += f" (as {dest_name})"
    exclude = [] if include_bags else ["recorded_data/"]
    if not include_bags:
        click.secho("Excluding rosbags (recorded_data/). Use --include-bags to include.", fg="yellow")
    click.secho(f"Transferring {label} -> {len(reachable)} machines", fg="cyan")
    for dst in reachable:
        dst_path = f"{fc.output_root}/{dest_name}{path_suffix}"
        click.echo(f"  -> {dst['name']} ({dst['ip']})...")
        ok, method, msg = rsync_transfer(
            src["user"], src["ip"], src_path,
            dst["user"], dst["ip"], dst_path,
            delete=delete, relay=relay, stream=True, exclude=exclude,
        )
        if ok:
            click.secho(f"  {dst['name']}: OK ({method})", fg="green")
        else:
            click.secho(f"  {dst['name']}: FAIL ({method}): {msg}", fg="red")


# --- verify ---


@cli.command()
@click.option("--experiment", "-e", required=True, help="Experiment to verify")
@click.option("--machine", "-m", multiple=True, help="Filter to specific machines")
@click.pass_context
def verify(ctx, experiment, machine):
    """Verify map consistency across machines."""
    fc = FleetContext(
        ctx.obj["network"], ctx.obj["topology"], ctx.obj["output_root"]
    )
    names = list(machine) if machine else None
    machines = fc.machines(names=names)

    def fetch_hashes(m):
        return hash_remote_experiment(m["user"], m["ip"], fc.output_root, experiment)

    results = run_parallel(fetch_hashes, machines)
    machine_hashes = {m["name"]: h for m, h in results if isinstance(h, dict)}

    if not machine_hashes:
        click.secho("No machines returned hash data.", fg="yellow")
        return

    # Collect all files across all machines
    all_files = sorted(set(f for h in machine_hashes.values() for f in h))
    machine_names = sorted(machine_hashes.keys())

    table = Table(title=f"Map Verification: {experiment}")
    table.add_column("File", style="bold")
    for mname in machine_names:
        table.add_column(mname)

    diffs = 0
    for fpath in all_files:
        hashes_for_file = {mn: machine_hashes[mn].get(fpath) for mn in machine_names}
        unique_hashes = set(v for v in hashes_for_file.values() if v)
        is_consistent = len(unique_hashes) <= 1

        row = [fpath]
        for mn in machine_names:
            h = hashes_for_file[mn]
            if h is None:
                row.append("[dim]missing[/]")
                if unique_hashes:
                    is_consistent = False
            elif is_consistent:
                row.append("[green]OK[/]")
            else:
                row.append(f"[red]{h[:8]}[/]")
        if not is_consistent:
            diffs += 1
        table.add_row(*row)

    console.print(table)
    if diffs == 0:
        console.print("[bold green]All files consistent across machines.[/]")
    else:
        console.print(f"[bold red]{diffs} file(s) differ across machines.[/]")


# --- launch ---


@cli.command()
@click.option("--machine", "-m", multiple=True, help="Machines to launch on")
@click.option("--session", "-s", required=True, help="Tmux session name")
@click.option("--experiment", "-e", required=True, help="Experiment name (for output dir)")
@click.option("--prior-map", "-p", default=None, help="Prior map path on remote machines")
@click.option("--base-station", is_flag=True, help="Also launch base station on willow")
@click.option("--force", "-f", is_flag=True, help="Overwrite existing output directories")
@click.option("--yes", "-y", is_flag=True, help="Skip confirmation")
@click.option("--dry-run", "-d", is_flag=True, help="Show commands without executing")
@click.pass_context
def launch(ctx, machine, session, experiment, prior_map, base_station, force, yes, dry_run):
    """Launch run-adt4 remotely on fleet robots."""
    fc = FleetContext(
        ctx.obj["network"], ctx.obj["topology"], ctx.obj["output_root"]
    )
    names = list(machine) if machine else None
    robots = fc.machines(roles=["robot"], names=names)

    targets = []
    for m in robots:
        sess = session
        targets.append((m, sess))

    if base_station:
        bs_machines = fc.machines(roles=["base_station"])
        for m in bs_machines:
            targets.append((m, "base_station"))

    if not targets:
        click.secho("No target machines found.", fg="yellow")
        return

    table = Table(title="Launch Plan")
    table.add_column("Machine", style="bold")
    table.add_column("Session")
    table.add_column("Platform")
    table.add_column("Output Dir")
    table.add_column("Prior Map")

    cmds = []
    force_flag = " -f" if force else ""
    for m, sess in targets:
        output_dir = f"{fc.output_root}/{experiment}"
        prior_flag = f" -p {_quote_path(prior_map)}" if prior_map else ""
        remote_cmd = (
            f"cd ~/dcist_ws && source install/setup.zsh && "
            f"src/awesome_dcist_t4/dcist_launch_system/bin/run-adt4 "
            f"{shlex.quote(sess)} -n {shlex.quote(m['name'])} "
            f"-c {shlex.quote(m['platform_id'])} "
            f"-o {_quote_path(output_dir)} -y{force_flag}{prior_flag} "
            f"--tmuxp-args \"-d\""
        )
        table.add_row(
            m["name"], sess, m["platform_id"] or "---",
            output_dir, prior_map or "---",
        )
        cmds.append((m, remote_cmd, sess))

    console.print(table)

    if dry_run:
        click.secho("\nDry run — commands that would be executed:", fg="cyan")
        for m, cmd, _ in cmds:
            click.echo(f"  ssh {m['user']}@{m['ip']} \"{cmd}\"")
        return

    # Pre-launch check for existing sessions
    click.echo("Checking for running sessions...")
    def check_session(item):
        m, _, sess = item
        rc, _, _ = ssh_cmd(m["user"], m["ip"], f"tmux has-session -t {shlex.quote(sess)} 2>/dev/null", timeout=5)
        return m['name'], rc == 0, sess

    session_checks = run_parallel(check_session, cmds)
    conflicts = [r for _, r in session_checks if r[1]]
    if conflicts:
        for mname, _, sess in conflicts:
            click.secho(f"  Warning: Session '{sess}' is already running on {mname}.", fg="yellow")
        if click.confirm("Terminate existing sessions and proceed?"):
            for mname, _, sess in conflicts:
                # Find the machine dict
                m = next(m for m, _, _ in cmds if m["name"] == mname)
                click.echo(f"  Terminating session on {mname}...")
                ssh_cmd(m["user"], m["ip"], f"tmux kill-session -t {shlex.quote(sess)}", timeout=5)
        else:
            click.secho("Aborted by user.", fg="red")
            return

    if not yes:
        click.confirm("Proceed with launch?", abort=True)

    def do_launch(item):
        m, cmd, _ = item
        rc, out, err = ssh_cmd(m["user"], m["ip"], cmd, timeout=30)
        return rc, out, err

    results = run_parallel(do_launch, cmds)
    for (m, _), (rc_or_exc) in results:
        if isinstance(rc_or_exc, Exception):
            click.secho(f"  {m['name']}: ERROR - {rc_or_exc}", fg="red")
        else:
            rc, out, err = rc_or_exc
            if rc == 0:
                click.secho(f"  {m['name']}: launched", fg="green")
            else:
                click.secho(f"  {m['name']}: FAILED (rc={rc}) {err}", fg="red")


# --- monitor ---


@cli.command()
@click.option("--machine", "-m", multiple=True, help="Filter to specific machines")
@click.option("--watch", "-w", is_flag=True, help="Auto-refresh every 10s")
@click.pass_context
def monitor(ctx, machine, watch):
    """Monitor fleet status (tmux sessions, ROS2 procs, load, disk)."""
    fc = FleetContext(
        ctx.obj["network"], ctx.obj["topology"], ctx.obj["output_root"]
    )
    names = list(machine) if machine else None
    machines = fc.machines(names=names)

    def _print_status():
        def fetch(m):
            return get_remote_status(m["user"], m["ip"])

        results = run_parallel(fetch, machines)

        table = Table(title="Fleet Monitor")
        table.add_column("Machine", style="bold")
        table.add_column("Tmux Sessions")
        table.add_column("ROS2 Procs")
        table.add_column("Load")
        table.add_column("Disk Free")

        for m, st in sorted(results, key=lambda x: x[0]["name"]):
            if isinstance(st, Exception):
                table.add_row(m["name"], f"[red]{st}[/]", "", "", "")
                continue
            table.add_row(
                m["name"],
                st["tmux_sessions"],
                st["ros2_procs"],
                st["load"],
                st["disk"],
            )
        console.print(table)

    if not watch:
        _print_status()
        return

    import time

    try:
        while True:
            console.clear()
            _print_status()
            console.print("[dim]Refreshing in 10s... (Ctrl+C to stop)[/]")
            time.sleep(10)
    except KeyboardInterrupt:
        pass


@cli.command()
@click.option("--machine", "-m", multiple=True, help="Filter to specific machines")
@click.option("--dry-run", is_flag=True, help="Preview configs without deploying")
@click.pass_context
def zenoh(ctx, machine, dry_run):
    """Generate and deploy Zenoh router configs based on topology.

    Base stations get connect endpoints to robots (star topology).
    Robots listen only — no outbound connections.
    """
    fc = FleetContext(
        ctx.obj["network"], ctx.obj["topology"], ctx.obj["output_root"]
    )
    names = list(machine) if machine else None
    machines = fc.machines(names=names)

    table = Table(title=f"Zenoh Configs — network: {fc.network}")
    table.add_column("Machine", style="bold")
    table.add_column("Role")
    table.add_column("Connect Endpoints")
    table.add_column("Status")

    for m in sorted(machines, key=lambda x: x["name"]):
        mname = m["name"]
        try:
            endpoints = generate_zenoh_endpoints(fc.topology, fc.network, mname)
        except KeyError:
            table.add_row(mname, m["role"], "?", "[red]No address[/]")
            continue

        n = len(endpoints)
        connect_str = f"{n} robot(s)" if n else "[dim]none (listen only)[/]"

        if dry_run:
            table.add_row(mname, m["role"], connect_str, "[yellow]dry-run[/]")
            for ep in endpoints:
                console.print(f"  [dim]{mname} → {ep}[/]")
        else:
            ok, msg = deploy_zenoh_config(m["user"], m["ip"], endpoints)
            status = f"[green]{msg}[/]" if ok else f"[red]{msg}[/]"
            table.add_row(mname, m["role"], connect_str, status)

    console.print(table)
    if dry_run:
        console.print("[yellow]Dry run — no configs deployed. Remove --dry-run to deploy.[/]")


# ---------------------------------------------------------------------------
# TUI mode (textual)
# ---------------------------------------------------------------------------


def _launch_tui(network, topology_path, output_root):
    """Launch the interactive Textual TUI."""
    try:
        from textual.app import App, ComposeResult
        from textual.binding import Binding
        from textual.containers import Horizontal, Vertical, VerticalScroll
        from textual.screen import ModalScreen
        from textual.widgets import (
            Button,
            DataTable,
            Footer,
            Header,
            Input,
            Label,
            ProgressBar,
            RichLog,
            Rule,
            SelectionList,
            Static,
            Tree,
        )
    except ImportError:
        click.secho(
            "textual not installed. Install with: pip install textual\n"
            "Falling back to CLI mode. Use subcommands (status, maps, etc.).",
            fg="yellow",
        )
        return

    topo = load_topology(topology_path)
    active_network = network or detect_network(topo)
    if not active_network:
        click.secho("Could not detect network. Use --network.", fg="red")
        sys.exit(1)

    all_machines = resolve_machines(topo, active_network)

    # Runtime config overrides (editable in TUI)
    runtime_config = {m["name"]: dict(m) for m in all_machines}
    _deleted_machines = set()  # track explicit removals for save

    # Cache local IPs for detecting when a base station is the local machine
    from dcist_launch_system.fleet_helpers import get_local_ips
    _local_ips = set(get_local_ips())

    def _fuzzy_match(query, text):
        """Subsequence fuzzy match — all chars of query appear in order in text."""
        if not query:
            return True
        query = query.lower()
        text = text.lower()
        qi = 0
        for ch in text:
            if ch == query[qi]:
                qi += 1
                if qi == len(query):
                    return True
        return False

    # ---- Maps Screen ----

    class ConfirmSessionKillScreen(ModalScreen[bool]):
        def __init__(self, message: str):
            super().__init__()
            self.message = message

        def compose(self) -> ComposeResult:
            yield Vertical(
                Label(self.message),
                Rule(),
                Horizontal(
                    Button("Yes, Terminate", variant="error", id="btn_yes"),
                    Button("No, Abort", variant="primary", id="btn_no"),
                ),
                id="confirm_kill_dialog"
            )

        def on_button_pressed(self, event: Button.Pressed) -> None:
            self.dismiss(event.button.id == "btn_yes")

    def _check_sessions_and_prompt(app, targets, session_name, log):
        """Check for running tmux sessions and prompt user in TUI threads to kill them."""
        def check(m):
            rc, _, _ = ssh_cmd(m["user"], m["ip"], f"tmux has-session -t {shlex.quote(session_name)} 2>/dev/null", timeout=5)
            if rc == 0:
                return m["name"]
            return None

        app.call_from_thread(log.write, f"  [dim]Checking for existing '{session_name}' sessions...[/]")
        results = run_parallel(check, targets)
        conflicts = [r for _, r in results if isinstance(r, str)]

        if not conflicts:
            return True

        app.call_from_thread(
            log.write,
            f"  [yellow]Session '{session_name}' already running on: {', '.join(conflicts)}[/]"
        )

        user_decision = [None]
        ev = threading.Event()

        def ask():
            def on_dismiss(result):
                user_decision[0] = result
                ev.set()
            msg = f"Session '{session_name}' is already running on {len(conflicts)} machine(s):\n{', '.join(conflicts)}\n\nTerminate existing sessions and proceed?"
            app.push_screen(ConfirmSessionKillScreen(msg), on_dismiss)

        app.call_from_thread(ask)
        ev.wait()

        if user_decision[0]:
            for m in targets:
                if m["name"] in conflicts:
                    app.call_from_thread(log.write, f"  [dim]Terminating session {session_name} on {m['name']}...[/]")
                    ssh_cmd(m["user"], m["ip"], f"tmux kill-session -t {shlex.quote(session_name)}", timeout=5)
            return True
        else:
            app.call_from_thread(log.write, "[red]Launch aborted by user.[/]")
            return False

    class PriorMapSelector(Vertical):
        """Reusable widget for browsing and selecting prior maps from fleet nodes.

        Uses the same Tree-based approach as MapsScreen. Click an experiment
        to select it. Experiments with both hydra + roman are marked with a green check.
        """
        def compose(self) -> ComposeResult:
            yield Label("Prior map (click to select, or type custom path):")
            yield Input(placeholder="Filter experiments...", id="prior_search")
            yield Tree("Fleet Experiments", id="prior_tree")
            yield Input(placeholder="(optional) custom: machine:~/adt4_output/exp", id="prior_input")

        def on_mount(self):
            self._selected_path = ""
            self._selected_source = None
            self._all_results = []
            self.set_timer(0.5, self.refresh_priors)

        def refresh_priors(self, log_widget=None):

            def do_fetch():
                machines = [m for m in runtime_config.values() if m.get("online", False)]
                def fetch(m):
                    return list_remote_experiments(m["user"], m["ip"], output_root)
                return run_parallel(fetch, machines)

            def on_done(results):
                self._all_results = results
                self._populate_tree()
                if log_widget:
                    total = sum(
                        len(exps) for _, exps in results
                        if not isinstance(exps, Exception)
                    )
                    log_widget.write(f"[green]Found {total} experiments across fleet.[/]")

            def _fetch_then_done():
                result = do_fetch()
                self.app.call_from_thread(on_done, result)

            self.app.run_worker(_fetch_then_done, thread=True)

        def _populate_tree(self, query=""):
            tree = self.query_one("#prior_tree", Tree)
            tree.clear()
            for m, exps in sorted(self._all_results, key=lambda x: x[0]["name"]):
                if isinstance(exps, Exception):
                    node = tree.root.add(m["name"], expand=True)
                    node.add_leaf(f"[red]Error: {exps}[/]")
                    continue
                filtered = [
                    e for e in sorted(exps, key=lambda e: e["name"])
                    if _fuzzy_match(query, e["name"])
                ] if query else sorted(exps, key=lambda e: e["name"])
                if not filtered and query:
                    continue
                node = tree.root.add(m["name"], expand=True)
                if not filtered:
                    node.add_leaf("[dim]no experiments[/]")
                    continue
                for exp in filtered:
                    subdirs = exp.get("subdirs", [])
                    has_prior = "hydra" in subdirs and "roman" in subdirs
                    tag = " [green]\u2714[/]" if has_prior else ""
                    label = f"{exp['name']}  ({exp.get('size', '?')}){tag}"
                    leaf = node.add_leaf(label)
                    leaf.data = {
                        "machine": m["name"],
                        "experiment": exp["name"],
                        "path": f"{output_root}/{exp['name']}",
                    }
            tree.root.expand_all()

        def on_input_changed(self, event: Input.Changed):
            if event.input.id == "prior_search" and self._all_results:
                self._populate_tree(event.value.strip())

        def on_tree_node_selected(self, event):
            node = event.node
            if hasattr(node, "data") and node.data and "experiment" in node.data:
                self._selected_path = node.data["path"]
                self._selected_source = node.data["machine"]

        def get_prior_map(self):
            """Return (prior_path, source_machine_name) or ("", None)."""
            custom = self.query_one("#prior_input", Input).value.strip()
            if custom:
                if ":" in custom:
                    parts = custom.split(":", 1)
                    return parts[1], parts[0]
                return custom, None
            if self._selected_path:
                return self._selected_path, self._selected_source
            return "", None

    class MapsScreen(ModalScreen):
        BINDINGS = [
            Binding("escape", "dismiss", "Back", priority=True),
            Binding("t", "transfer_selected", "Transfer", priority=True),
            Binding("v", "verify_selected", "Verify", priority=True),
            Binding("r", "refresh_maps", "Refresh", priority=True),
        ]

        def __init__(self):
            super().__init__()
            self.selected_machine = None
            self.selected_experiment = None
            self._all_results = []  # cached fetch results

        def compose(self) -> ComposeResult:
            yield Vertical(
                Label("[bold]Map Browser[/] — select an experiment"),
                Input(placeholder="Search experiments...", id="map_search"),
                Rule(),
                Tree("Fleet Maps", id="map_tree"),
                Rule(),
                RichLog(id="map_log", highlight=True, markup=True, max_lines=50),
            )
            yield Footer()

        def action_refresh_maps(self):
            self._refresh_maps()

        def on_mount(self):
            self._refresh_maps()

        def _refresh_maps(self):
            tree = self.query_one("#map_tree", Tree)
            log = self.query_one("#map_log", RichLog)
            tree.clear()
            log.write("[dim]Fetching experiments from fleet...[/]")

            def do_fetch():
                machines = [m for m in runtime_config.values() if m.get("online", False)]

                def fetch(m):
                    return list_remote_experiments(m["user"], m["ip"], output_root)

                return run_parallel(fetch, machines)

            def on_done(results):
                self._all_results = results
                query = self.query_one("#map_search", Input).value.strip()
                self._populate_tree(query)
                log.write("[green]Maps loaded.[/]")

            def bg():
                results = do_fetch()
                self.app.call_from_thread(on_done, results)

            threading.Thread(target=bg, daemon=True).start()

        def _populate_tree(self, query=""):
            tree = self.query_one("#map_tree", Tree)
            tree.clear()
            for m, exps in sorted(self._all_results, key=lambda x: x[0]["name"]):
                if isinstance(exps, Exception):
                    node = tree.root.add(m["name"], expand=True)
                    node.data = {"machine": m["name"]}
                    node.add_leaf(f"[red]Error: {exps}[/]")
                    continue
                filtered = [
                    e for e in sorted(exps, key=lambda e: e["name"])
                    if _fuzzy_match(query, e["name"])
                ] if query else sorted(exps, key=lambda e: e["name"])
                if not filtered and query:
                    continue  # hide machines with no matches
                node = tree.root.add(m["name"], expand=True)
                node.data = {"machine": m["name"]}
                if not filtered:
                    node.add_leaf("[dim]no experiments[/]")
                    continue
                for exp in filtered:
                    subdirs_str = ", ".join(exp["subdirs"]) if exp["subdirs"] else ""
                    label = f"{exp['name']}  [{subdirs_str}]  ({exp['size']})"
                    leaf = node.add_leaf(label)
                    leaf.data = {"machine": m["name"], "experiment": exp["name"]}
            tree.root.expand_all()

        def on_input_changed(self, event: Input.Changed):
            if event.input.id == "map_search" and self._all_results:
                self._populate_tree(event.value.strip())

        def on_tree_node_selected(self, event):
            node = event.node
            if hasattr(node, "data") and node.data and "experiment" in node.data:
                self.selected_machine = node.data["machine"]
                self.selected_experiment = node.data["experiment"]
                log = self.query_one("#map_log", RichLog)
                log.write(
                    f"Selected: [bold]{self.selected_machine}[/]:"
                    f"[cyan]{self.selected_experiment}[/]"
                    f" — press [bold]T[/] to transfer, [bold]V[/] to verify"
                )

        def action_transfer_selected(self):
            if not self.selected_experiment:
                self.query_one("#map_log", RichLog).write("[yellow]Select an experiment first.[/]")
                return
            self.app.push_screen(
                TransferScreen(self.selected_machine, self.selected_experiment)
            )

        def action_verify_selected(self):
            if not self.selected_experiment:
                self.query_one("#map_log", RichLog).write("[yellow]Select an experiment first.[/]")
                return
            self.app.push_screen(VerifyScreen(self.selected_experiment))

    # ---- Transfer Screen ----

    class TransferScreen(ModalScreen):
        BINDINGS = [
            Binding("escape", "dismiss", "Back", priority=True),
            Binding("t", "start_transfer", "Start Transfer", priority=True),
        ]

        def __init__(self, src_machine, experiment):
            super().__init__()
            self.src_machine = src_machine
            self.experiment = experiment
            self._transferring = False

        def compose(self) -> ComposeResult:
            others = [
                (m["name"], m["name"])
                for m in runtime_config.values()
                if m["name"] != self.src_machine and m.get("online", False)
            ]
            yield Vertical(
                Label(
                    f"[bold]Transfer[/] {self.src_machine}:{self.experiment} -> select destinations"
                ),
                Rule(),
                SelectionList(*others, id="dest_select"),
                Rule(),
                Vertical(id="progress_area"),
                RichLog(id="transfer_log", highlight=True, markup=True, max_lines=100),
            )
            yield Footer()

        def action_start_transfer(self):
            self._do_transfer()

        def _do_transfer(self):
            if self._transferring:
                return
            sel = self.query_one("#dest_select", SelectionList)
            selected_names = list(sel.selected)
            if not selected_names:
                self.query_one("#transfer_log", RichLog).write(
                    "[yellow]Select at least one destination.[/]"
                )
                return

            self._transferring = True
            log = self.query_one("#transfer_log", RichLog)
            src = runtime_config[self.src_machine]
            src_path = f"{output_root}/{self.experiment}"
            dest_name = f"prior_{self.experiment}"

            log.write(f"[yellow]Excluding rosbags. Saving as {dest_name}[/]")

            # Build progress bars in the UI
            area = self.query_one("#progress_area", Vertical)
            area.remove_children()
            for dname in selected_names:
                area.mount(
                    Vertical(
                        Label(f"  {dname}:"),
                        ProgressBar(total=100, show_eta=False, id=f"pb_{dname}"),
                        id=f"pbrow_{dname}",
                    )
                )

            def do_transfers():
                try:
                    for i, dname in enumerate(selected_names):
                        dst = runtime_config[dname]
                        dst_path = f"{output_root}/{dest_name}"
                        self.app.call_from_thread(
                            log.write, f"Transferring to [bold]{dname}[/]..."
                        )

                        def make_cb(name):
                            def cb(pct):
                                self.app.call_from_thread(
                                    self._update_progress, name, pct
                                )
                            return cb

                        ok, method, msg = rsync_transfer(
                            src["user"], src["ip"], src_path,
                            dst["user"], dst["ip"], dst_path,
                            exclude=["recorded_data/"],
                            progress_callback=make_cb(dname),
                        )
                        if ok:
                            self.app.call_from_thread(
                                self._update_progress, dname, 100
                            )
                            self.app.call_from_thread(
                                log.write, f"  [green]{dname}: OK ({method})[/]"
                            )
                        else:
                            self.app.call_from_thread(
                                log.write, f"  [red]{dname}: FAIL ({method}) {msg}[/]"
                            )
                    self.app.call_from_thread(log.write, "[bold]Transfer complete.[/]")
                finally:
                    self._transferring = False

            threading.Thread(target=do_transfers, daemon=True).start()

        def _update_progress(self, dname, pct):
            try:
                bar = self.query_one(f"#pb_{dname}", ProgressBar)
                bar.update(progress=pct)
            except Exception:
                pass

    # ---- Verify Screen ----

    class VerifyScreen(ModalScreen):
        BINDINGS = [Binding("escape", "dismiss", "Back", priority=True)]

        def __init__(self, experiment):
            super().__init__()
            self.experiment = experiment

        def compose(self) -> ComposeResult:
            yield Vertical(
                Label(f"[bold]Verify:[/] {self.experiment}"),
                Rule(),
                DataTable(id="verify_table"),
                RichLog(id="verify_log", highlight=True, markup=True, max_lines=50),
                Footer(),
            )

        def on_mount(self):
            log = self.query_one("#verify_log", RichLog)
            log.write("[dim]Computing checksums across fleet...[/]")

            def do_verify():
                machines = [m for m in runtime_config.values() if m.get("online", False)]

                def fetch(m):
                    return hash_remote_experiment(m["user"], m["ip"], output_root, self.experiment)

                return run_parallel(fetch, machines)

            def on_done(results):
                table = self.query_one("#verify_table", DataTable)
                machine_hashes = {
                    m["name"]: h for m, h in results if isinstance(h, dict) and h
                }
                if not machine_hashes:
                    log.write("[yellow]No hash data returned.[/]")
                    return

                all_files = sorted(set(f for h in machine_hashes.values() for f in h))
                mnames = sorted(machine_hashes.keys())

                table.add_column("File", key="file")
                for mn in mnames:
                    table.add_column(mn, key=mn)

                diffs = 0
                for fpath in all_files:
                    hashes = {mn: machine_hashes[mn].get(fpath) for mn in mnames}
                    unique = set(v for v in hashes.values() if v)
                    consistent = len(unique) <= 1 and all(v for v in hashes.values())
                    row = [fpath]
                    for mn in mnames:
                        h = hashes[mn]
                        if h is None:
                            row.append("MISSING")
                            consistent = False
                        elif consistent:
                            row.append("OK")
                        else:
                            row.append(h[:8])
                    if not consistent:
                        diffs += 1
                    table.add_row(*row)

                if diffs == 0:
                    log.write("[bold green]All files consistent.[/]")
                else:
                    log.write(f"[bold red]{diffs} file(s) differ.[/]")

            def bg():
                results = do_verify()
                self.app.call_from_thread(on_done, results)

            threading.Thread(target=bg, daemon=True).start()

    # ---- Config Screen ----

    class ConfigScreen(ModalScreen):
        BINDINGS = [
            Binding("escape", "dismiss", "Back", priority=True),
            Binding("f2", "add_machine_action", "Add Machine", priority=True),
            Binding("f3", "recheck_action", "Recheck All", priority=True),
            Binding("f5", "save_action", "Save to YAML", priority=True),
        ]

        def compose(self) -> ComposeResult:
            yield VerticalScroll(
                Label("[bold]Fleet Configuration[/] — edit machines for this session"),
                Label("[dim]Changes are session-only until you save (F5).[/]"),
                Rule(),
                Vertical(id="config_form"),
                Rule(),
                Label("[bold]Add Machine[/] (fill in fields, then press F2)"),
                Horizontal(
                    Label(" Name: "),
                    Input(placeholder="e.g. newton", id="add_name"),
                    Label(" Role: "),
                    Input(placeholder="robot or base_station", id="add_role", value="robot"),
                    Label(" IP: "),
                    Input(placeholder="e.g. 192.168.100.50", id="add_ip"),
                    Label(" Platform: "),
                    Input(placeholder="e.g. smaug", id="add_platform"),
                    id="add_row",
                ),
                Rule(),
                RichLog(id="config_log", highlight=True, markup=True, max_lines=20),
            )
            yield Footer()

        def on_mount(self):
            self._rebuild_form()

        def _rebuild_form(self):
            form = self.query_one("#config_form", Vertical)
            form.remove_children()
            ssh_conf = topo.get("ssh", {})
            robot_user = ssh_conf.get("robot_user", "swarm")
            base_user = ssh_conf.get("base_station_user", "rrg")

            for mname in sorted(runtime_config):
                mconf = runtime_config[mname]
                online = mconf.get("online")
                if online:
                    dot = "[green]\u25cf[/]"
                elif online is None:
                    dot = "[dim]\u25cb[/]"
                elif mconf.get("ping"):
                    dot = "[yellow]\u25cf[/]"
                else:
                    dot = "[red]\u25cf[/]"

                role_label = mconf["role"]
                is_robot = role_label == "robot"

                form.mount(
                    Vertical(
                        Horizontal(
                            Label(f" {dot} [bold]{mname}[/] ({role_label})  "),
                            Button("Remove", variant="error", id=f"rm_{mname}"),
                        ),
                        Horizontal(
                            Label("   IP: "),
                            Input(
                                value=mconf.get("ip", ""),
                                id=f"ip_{mname}",
                                placeholder="IP address",
                            ),
                            Label("  Platform ID: "),
                            Input(
                                value=mconf.get("platform_id", ""),
                                id=f"plat_{mname}",
                                placeholder="platform_id" if is_robot else "N/A",
                            ) if is_robot else Static("[dim]N/A[/]"),
                            Label(f"  User: {mconf.get('user', '?')}"),
                        ),
                        Rule(line_style="dashed"),
                        id=f"row_{mname}",
                    )
                )

        def on_input_changed(self, event: Input.Changed):
            input_id = event.input.id
            if not input_id:
                return
            if input_id.startswith("plat_"):
                mname = input_id[5:]
                if mname in runtime_config:
                    runtime_config[mname]["platform_id"] = event.value
            elif input_id.startswith("ip_"):
                mname = input_id[3:]
                if mname in runtime_config:
                    runtime_config[mname]["ip"] = event.value

        def on_button_pressed(self, event: Button.Pressed) -> None:
            """Handle per-machine Remove buttons."""
            bid = event.button.id
            if bid and bid.startswith("rm_"):
                log = self.query_one("#config_log", RichLog)
                mname = bid[3:]
                if mname in runtime_config:
                    del runtime_config[mname]
                    _deleted_machines.add(mname)
                    log.write(f"Removed [bold]{mname}[/] from session.")
                    self._rebuild_form()

        def action_add_machine_action(self):
            self._add_machine(self.query_one("#config_log", RichLog))

        def action_recheck_action(self):
            self._recheck(self.query_one("#config_log", RichLog))

        def action_save_action(self):
            self._save_topology(self.query_one("#config_log", RichLog))

        def _add_machine(self, log):
            name = self.query_one("#add_name", Input).value.strip()
            role = self.query_one("#add_role", Input).value.strip()
            ip = self.query_one("#add_ip", Input).value.strip()
            platform = self.query_one("#add_platform", Input).value.strip()

            if not name or not ip:
                log.write("[yellow]Name and IP are required.[/]")
                return
            try:
                import ipaddress as _ipa
                _ipa.ip_address(ip)
            except ValueError:
                log.write(f"[yellow]Invalid IP address: {ip}[/]")
                return
            if name in runtime_config:
                log.write(f"[yellow]{name} already exists. Edit it above or remove first.[/]")
                return
            if role not in ("robot", "base_station"):
                log.write("[yellow]Role must be 'robot' or 'base_station'.[/]")
                return

            ssh_conf = topo.get("ssh", {})
            user = ssh_conf.get("base_station_user", "rrg") if role == "base_station" else ssh_conf.get("robot_user", "swarm")
            runtime_config[name] = {
                "name": name,
                "role": role,
                "ip": ip,
                "user": user,
                "desc": "",
                "platform_id": platform if role == "robot" else "",
            }
            log.write(f"Added [bold]{name}[/] ({role}) at {ip}")
            # Clear the add fields
            self.query_one("#add_name", Input).value = ""
            self.query_one("#add_ip", Input).value = ""
            self.query_one("#add_platform", Input).value = ""
            self._rebuild_form()

        def _recheck(self, log):
            log.write("[dim]Rechecking connectivity...[/]")

            def do_check():
                machines = list(runtime_config.values())
                reachable, unreachable = filter_reachable(machines)
                return reachable + unreachable

            def on_done(all_machines):
                n_online = sum(1 for m in all_machines if m.get("online"))
                log.write(f"[green]{n_online}/{len(all_machines)} machines online.[/]")
                self._rebuild_form()

            def bg():
                results = do_check()
                self.app.call_from_thread(on_done, results)

            threading.Thread(target=bg, daemon=True).start()

        def _save_topology(self, log):
            """Write current runtime_config back to topology.yaml."""
            topo_machines = topo.get("machines", {})

            # Apply runtime_config changes into topo
            # Track which machines are in runtime_config
            seen = set()
            for mname, mconf in runtime_config.items():
                seen.add(mname)
                if mname not in topo_machines:
                    # New machine — create entry
                    topo_machines[mname] = {
                        "role": mconf["role"],
                        "addresses": {active_network: mconf["ip"]},
                    }
                    if mconf.get("desc"):
                        topo_machines[mname]["desc"] = mconf["desc"]
                else:
                    # Existing machine — update IP and platform_id
                    entry = topo_machines[mname]
                    addrs = entry.setdefault("addresses", {})
                    addrs[active_network] = mconf["ip"]

                # Update platform_id for robots
                if mconf["role"] == "robot" and mconf.get("platform_id"):
                    topo_machines[mname]["platform_id"] = mconf["platform_id"]

            # Only remove machines that were explicitly deleted by the user
            # (not all machines absent from runtime_config, since that only
            # contains machines for the active network)
            for mname in list(_deleted_machines):
                if mname in topo_machines:
                    del topo_machines[mname]
            _deleted_machines.clear()

            topo["machines"] = topo_machines

            topo_path = pathlib.Path(topology_path) if topology_path else _DEFAULT_TOPOLOGY
            try:
                with open(topo_path, "w") as f:
                    yaml.dump(topo, f, default_flow_style=False, sort_keys=False)
                log.write(f"[green]Saved to {topo_path}[/]")
            except OSError as e:
                log.write(f"[red]Failed to save: {e}[/]")

    # ---- Launch Screen ----

    class LaunchScreen(ModalScreen):
        BINDINGS = [
            Binding("escape", "dismiss", "Back", priority=True),
            Binding("m", "preset_mapping", "Mapping (m)", priority=True),
            Binding("r", "preset_relocalize", "Relocalize (r)", priority=True),
            Binding("d", "dry_run", "Dry Run", priority=True),
            Binding("g", "do_launch", "Launch (g)", priority=True),
            Binding("z", "deploy_zenoh", "Deploy Zenoh (z)", priority=True),
            Binding("p", "browse_prior", "Refresh Priors (p)", priority=True),
            Binding("f2", "toggle_log_size", "Log Size [F2]", priority=True),
        ]

        DEFAULT_CSS = """
        LaunchScreen #robot_select {
            max-height: 6;
        }
        LaunchScreen #session_select {
            max-height: 12;
        }
        LaunchScreen #bs_select {
            max-height: 4;
        }
        LaunchScreen #bs_session_select {
            max-height: 6;
        }
        LaunchScreen #prior_tree {
            min-height: 8;
            max-height: 16;
        }
        LaunchScreen #launch_log {
            min-height: 12;
        }
        """

        _LOG_SIZES = [12, 24, 40]

        def __init__(self, mode=None):
            super().__init__()
            self._launching = False
            self._mode = mode  # None=manual, "mapping", "relocalize"
            self._log_size_idx = 0

        def compose(self) -> ComposeResult:
            robots = [
                (m["name"], m["name"], m.get("online", False))
                for m in runtime_config.values()
                if m["role"] == "robot"
            ]
            base_stations = [
                (m["name"], f"{m['name']} (local)" if m["ip"] in _local_ips else m["name"], m.get("online", False) or m["ip"] in _local_ips)
                for m in runtime_config.values()
                if m["role"] == "base_station"
            ]
            self._all_sessions = sorted(
                [f.stem for f in _TMUX_DIR.glob("*.yaml")]
            ) if _TMUX_DIR.exists() else []

            yield VerticalScroll(
                Label("[bold]Launch[/] — m=mapping, r=relocalize, g=launch, d=dry run, p=refresh priors"),
                Rule(),
                Label("Select robots:"),
                SelectionList(*robots, id="robot_select"),
                Rule(),
                Label("Robot session:"),
                Input(placeholder="Filter sessions...", id="session_search"),
                SelectionList(*[(s, s) for s in self._all_sessions], id="session_select"),
                Rule(),
                Label("Base station (optional):"),
                SelectionList(*base_stations, id="bs_select"),
                Label("Base station session:"),
                SelectionList(
                    *[(s, s) for s in self._all_sessions if "base_station" in s],
                    id="bs_session_select",
                ),
                Rule(),
                Label("Experiment (saved to ~/adt4_output/<name>/, e.g. 03252026_building_test):"),
                Input(placeholder="date_description", id="experiment_input"),
                Rule(),
                PriorMapSelector(id="launch_prior_selector"),
                Rule(),
                Vertical(id="launch_progress_area"),
                RichLog(id="launch_log", highlight=True, markup=True, max_lines=100),
            )
            yield Footer()

        def on_mount(self):
            if self._mode:
                self._apply_preset(self._mode)

        def action_preset_mapping(self):
            self._mode = "mapping"
            self._apply_preset("mapping")

        def action_preset_relocalize(self):
            self._mode = "relocalize"
            self._apply_preset("relocalize")

        def _apply_preset(self, mode):
            """Auto-populate selections from fleet_defaults in topology."""
            defaults = topo.get("fleet_defaults", {})
            spot_platforms = set(defaults.get("spot_platforms", ["smaug", "topaz"]))
            sessions_cfg = defaults.get("sessions", {})
            mode_sessions = sessions_cfg.get(mode, {})
            spot_session = mode_sessions.get("spot", "")
            phoenix_session = mode_sessions.get("phoenix", "")
            bs_session = defaults.get("base_station_session", "")

            log = self.query_one("#launch_log", RichLog)
            log.write(f"[bold cyan]Auto-populating for {mode} mode...[/]")

            # Rebuild robot list with online robots pre-selected
            robot_sel = self.query_one("#robot_select", SelectionList)
            robot_sel.clear_options()
            for m in runtime_config.values():
                if m["role"] == "robot":
                    selected = m.get("online", False)
                    robot_sel.add_option((m["name"], m["name"], selected))

            # Pick session based on first online robot's platform
            first_robot = next(
                (m for m in runtime_config.values()
                 if m["role"] == "robot" and m.get("online")),
                None,
            )
            target_session = ""
            if first_robot:
                target_session = spot_session if first_robot.get("platform_id") in spot_platforms else phoenix_session

            # Rebuild session list with target pre-selected
            if target_session:
                sess_sel = self.query_one("#session_select", SelectionList)
                sess_sel.clear_options()
                for s in self._all_sessions:
                    sess_sel.add_option((s, s, s == target_session))
                log.write(f"  Robot session: [cyan]{target_session}[/]")

            # Rebuild BS list with local pre-selected
            local_bs = None
            bs_sel = self.query_one("#bs_select", SelectionList)
            bs_sel.clear_options()
            for m in runtime_config.values():
                if m["role"] == "base_station":
                    is_local = m["ip"] in _local_ips
                    bs_sel.add_option((m["name"], f"{m['name']} (local)" if is_local else m["name"], is_local))
                    if is_local:
                        local_bs = m["name"]
            if local_bs:
                log.write(f"  Base station: [cyan]{local_bs} (local)[/]")

            # Rebuild BS session list with default pre-selected
            bs_sess_sel = self.query_one("#bs_session_select", SelectionList)
            bs_sess_sel.clear_options()
            for s in self._all_sessions:
                if "base_station" in s:
                    bs_sess_sel.add_option((s, s, s == bs_session))
            if bs_session:
                log.write(f"  BS session: [cyan]{bs_session}[/]")

            if mode == "relocalize":
                log.write("[yellow]Relocalize mode: prior map is required. Select one below or press p to refresh.[/]")
            log.write("[dim]Review selections, then g=launch, d=dry run.[/]")

        def on_input_changed(self, event: Input.Changed):
            if event.input.id == "session_search":
                query = event.value.strip()
                sel = self.query_one("#session_select", SelectionList)
                sel.clear_options()
                for s in self._all_sessions:
                    if _fuzzy_match(query, s):
                        sel.add_option((s, s))

        def _get_selected_session(self):
            sel = self.query_one("#session_select", SelectionList)
            selected = list(sel.selected)
            return selected[0] if selected else ""

        def action_browse_prior(self):
            log = self.query_one("#launch_log", RichLog)
            self.query_one("#launch_prior_selector", PriorMapSelector).refresh_priors(log)

        def action_deploy_zenoh(self):
            """Deploy zenoh configs to selected robots + base station."""
            log = self.query_one("#launch_log", RichLog)

            # Gather selected robots
            robot_sel = self.query_one("#robot_select", SelectionList)
            robot_names = list(robot_sel.selected)
            targets = [runtime_config[n] for n in robot_names if n in runtime_config]

            # Add selected base station
            bs_sel = self.query_one("#bs_select", SelectionList)
            bs_names = list(bs_sel.selected)
            if bs_names and bs_names[0] in runtime_config:
                targets.append(runtime_config[bs_names[0]])

            if not targets:
                log.write("[yellow]No robots or base station selected.[/]")
                return

            names = ", ".join(m["name"] for m in targets)
            log.write(f"[bold]Deploying zenoh configs to: {names}[/]")
            log.write(f"  [dim]BS connects to robots: {', '.join(robot_names)}[/]")

            def do_deploy():
                results = []
                for m in targets:
                    try:
                        endpoints = generate_zenoh_endpoints(
                            topo, active_network, m["name"],
                            robot_filter=robot_names,
                        )
                        ok, msg = deploy_zenoh_config(m["user"], m["ip"], endpoints)
                        results.append((m["name"], ok, msg, len(endpoints)))
                    except KeyError:
                        results.append((m["name"], False, f"no address on {active_network}", 0))
                return results

            def on_done(results):
                for name, ok, msg, n_ep in results:
                    color = "green" if ok else "red"
                    log.write(f"  [{color}]{name}: {msg} ({n_ep} endpoint(s))[/{color}]")
                log.write("[bold]Zenoh deploy complete.[/]")

            def bg():
                results = do_deploy()
                self.app.call_from_thread(on_done, results)

            threading.Thread(target=bg, daemon=True).start()

        def action_toggle_log_size(self):
            self._log_size_idx = (self._log_size_idx + 1) % len(self._LOG_SIZES)
            new_h = self._LOG_SIZES[self._log_size_idx]
            log = self.query_one("#launch_log", RichLog)
            log.styles.min_height = new_h

        def _build_commands(self):
            log = self.query_one("#launch_log", RichLog)
            robot_sel = self.query_one("#robot_select", SelectionList)
            selected = list(robot_sel.selected)
            if not selected:
                return [], None, "No robots selected."

            session = self._get_selected_session()
            if not session:
                return [], None, "No session selected."

            experiment = self.query_one("#experiment_input", Input).value.strip()
            if not experiment:
                return [], None, "No experiment name provided."

            prior_path, prior_source = self.query_one("#launch_prior_selector", PriorMapSelector).get_prior_map()

            if self._mode == "relocalize" and not prior_path:
                return [], None, "Relocalize mode requires a prior map. Select one or press p to refresh."

            # If prior map comes from a source machine, targets get it as prior_<name>
            if prior_path and prior_source:
                exp_name = pathlib.Path(prior_path).name
                dest_prior = f"{output_root}/prior_{exp_name}"
                # Source machine uses original path, others use transferred path
                prior_paths = {}
                for rname in selected:
                    if rname == prior_source:
                        prior_paths[rname] = prior_path
                    else:
                        prior_paths[rname] = dest_prior
            else:
                prior_paths = {rname: prior_path for rname in selected}

            cmds = []
            for rname in selected:
                m = runtime_config[rname]
                out_dir = f"{output_root}/{experiment}"
                rprior = prior_paths.get(rname, "")
                prior_flag = f" -p {_quote_path(rprior)}" if rprior else ""
                remote_cmd = (
                    f"cd ~/dcist_ws && source install/setup.zsh && "
                    f"src/awesome_dcist_t4/dcist_launch_system/bin/run-adt4 "
                    f"{shlex.quote(session)} -n {shlex.quote(m['name'])} "
                    f"-c {shlex.quote(m['platform_id'])} "
                    f"-o {_quote_path(out_dir)} -y{prior_flag} "
                    f"--tmuxp-args \"-d\""
                )
                cmds.append((m, remote_cmd))

            prior_info = (prior_path, prior_source) if prior_path else None
            return cmds, prior_info, None


        def action_dry_run(self):
            log = self.query_one("#launch_log", RichLog)
            cmds, prior_info, err = self._build_commands()
            if err:
                log.write(f"[yellow]{err}[/]")
                return
            log.write("[bold cyan]Dry run:[/]")
            if prior_info:
                prior_path, prior_source = prior_info
                if prior_source:
                    exp_name = pathlib.Path(prior_path).name
                    dest_name = f"prior_{exp_name}"
                    for m, cmd in cmds:
                        if m["name"] != prior_source:
                            log.write(
                                f"  [dim]Transfer prior map: {prior_source} -> {m['name']} "
                                f"({exp_name} as {dest_name})[/]"
                            )
                    log.write(f"  [dim]Prior map path on targets: {output_root}/{dest_name}[/]")
            for m, cmd in cmds:
                log.write(f"  ssh {m['user']}@{m['ip']} \"{cmd}\"")

        def _transfer_prior_to_robot(self, prior_path, prior_source, target_machine, log, progress_callback=None):
            """Transfer prior map from source machine to target if it doesn't exist."""
            exp_name = pathlib.Path(prior_path).name
            dest_name = f"prior_{exp_name}"
            dest_path = f"{output_root}/{dest_name}"

            # Check if prior already exists on target
            rc, out, _ = ssh_cmd(
                target_machine["user"], target_machine["ip"],
                f"test -d {_quote_path(dest_path + '/hydra')} && test -d {_quote_path(dest_path + '/roman')} && echo OK",
                timeout=10,
            )
            if "OK" in out:
                self.app.call_from_thread(
                    log.write,
                    f"  [dim]{target_machine['name']}: prior map already present ({dest_name})[/]"
                )
                if progress_callback:
                    progress_callback(100)
                return True, dest_path

            # Need to transfer
            self.app.call_from_thread(
                log.write,
                f"  [cyan]Transferring prior map to {target_machine['name']}...[/]"
            )
            src = runtime_config.get(prior_source)
            if not src:
                self.app.call_from_thread(
                    log.write,
                    f"  [red]Source machine '{prior_source}' not found in config.[/]"
                )
                return False, ""

            ok, method, msg = rsync_transfer(
                src["user"], src["ip"], prior_path,
                target_machine["user"], target_machine["ip"], dest_path,
                relay=False, exclude=["recorded_data/"],
                progress_callback=progress_callback,
            )
            if ok:
                if progress_callback:
                    progress_callback(100)
                self.app.call_from_thread(
                    log.write,
                    f"  [green]{target_machine['name']}: prior map transferred ({method})[/]"
                )
                return True, dest_path
            else:
                self.app.call_from_thread(
                    log.write,
                    f"  [red]{target_machine['name']}: prior map transfer FAILED: {msg}[/]"
                )
                return False, ""

        def _update_launch_progress(self, name, pct):
            try:
                bar = self.query_one(f"#lpb_{name}", ProgressBar)
                bar.update(progress=pct)
            except Exception:
                pass

        def action_do_launch(self):
            if self._launching:
                return
            log = self.query_one("#launch_log", RichLog)
            cmds, prior_info, err = self._build_commands()
            if err:
                log.write(f"[yellow]{err}[/]")
                return

            self._launching = True
            experiment = self.query_one("#experiment_input", Input).value.strip()
            # Snapshot session name before thread starts (DOM queries from threads are unsafe)
            _launch_session_name = self._get_selected_session()

            # Snapshot base station selection
            bs_sel = self.query_one("#bs_select", SelectionList)
            bs_names = list(bs_sel.selected)
            _bs_machine = runtime_config.get(bs_names[0]) if bs_names else None
            bs_sess_sel = self.query_one("#bs_session_select", SelectionList)
            bs_sess_list = list(bs_sess_sel.selected)
            _bs_session = bs_sess_list[0] if bs_sess_list else None

            # Snapshot robot names for zenoh scoping
            robot_sel = self.query_one("#robot_select", SelectionList)
            _robot_names = list(robot_sel.selected)

            # Set up progress bars for transfers if needed
            area = self.query_one("#launch_progress_area", Vertical)
            area.remove_children()
            if prior_info:
                prior_path, prior_source = prior_info
                if prior_source:
                    targets = [m for m, _ in cmds if m["name"] != prior_source]
                    if targets:
                        area.mount(Label("[bold]Prior map transfer progress:[/]"))
                        for m in targets:
                            area.mount(
                                Vertical(
                                    Label(f"  {m['name']}:"),
                                    ProgressBar(total=100, show_eta=False, id=f"lpb_{m['name']}"),
                                )
                            )

            def do_launch():
                try:
                    # Phase 0: Deploy zenoh configs to selected robots + BS
                    deploy_targets = [runtime_config[n] for n in _robot_names if n in runtime_config]
                    if _bs_machine:
                        deploy_targets.append(_bs_machine)
                    if deploy_targets:
                        self.app.call_from_thread(
                            log.write, f"[bold]Deploying zenoh configs ({len(deploy_targets)} machines)...[/]"
                        )
                        all_ok = True
                        for m in deploy_targets:
                            try:
                                endpoints = generate_zenoh_endpoints(
                                    topo, active_network, m["name"],
                                    robot_filter=_robot_names,
                                )
                                ok, msg = deploy_zenoh_config(m["user"], m["ip"], endpoints)
                                color = "green" if ok else "red"
                                self.app.call_from_thread(
                                    log.write, f"  [{color}]{m['name']}: {msg} ({len(endpoints)} ep)[/{color}]"
                                )
                                if not ok:
                                    all_ok = False
                            except KeyError:
                                self.app.call_from_thread(
                                    log.write, f"  [dim]{m['name']}: no address on {active_network}[/]"
                                )
                        if not all_ok:
                            self.app.call_from_thread(
                                log.write, "[bold red]ABORT: zenoh deploy failed on some machines.[/]"
                            )
                            return

                    # Phase 1: Transfer prior maps if needed
                    if prior_info:
                        prior_path, prior_source = prior_info
                        if prior_source:
                            self.app.call_from_thread(
                                log.write, "[bold]Phase 1: Ensuring prior maps on all robots...[/]"
                            )
                            for m, cmd in cmds:
                                if m["name"] == prior_source:
                                    continue  # source already has it

                                def make_cb(mname):
                                    def cb(pct):
                                        self.app.call_from_thread(
                                            self._update_launch_progress, mname, pct
                                        )
                                    return cb

                                ok, dest_path = self._transfer_prior_to_robot(
                                    prior_path, prior_source, m, log,
                                    progress_callback=make_cb(m["name"]),
                                )
                                if not ok:
                                    self.app.call_from_thread(
                                        log.write,
                                        f"  [bold red]ABORT: could not transfer prior to {m['name']}[/]"
                                    )
                                    return

                    # Phase 1.5: Verify no conflicting tmux sessions
                    all_targets = [m for m, _ in cmds]
                    if _launch_session_name:
                        if not _check_sessions_and_prompt(self.app, all_targets, _launch_session_name, log):
                            return

                    # Phase 2: Launch on each robot
                    self.app.call_from_thread(
                        log.write,
                        "[bold]" + ("Phase 2: " if prior_info else "") + "Launching...[/]"
                    )
                    for m, cmd in cmds:
                        out_dir = f"{output_root}/{experiment}"
                        rc, out, _ = ssh_cmd(m["user"], m["ip"], f"test -d {_quote_path(out_dir)} && echo EXISTS", timeout=5)
                        if "EXISTS" in out:
                            self.app.call_from_thread(
                                log.write,
                                f"  [bold red]SKIP {m['name']}: {out_dir} already exists. "
                                f"Use CLI with --force to override.[/]"
                            )
                            continue
                        self.app.call_from_thread(
                            log.write, f"  Launching on [bold]{m['name']}[/]..."
                        )
                        rc, out, launch_err = ssh_cmd(m["user"], m["ip"], cmd, timeout=30)
                        if rc == 0:
                            self.app.call_from_thread(
                                log.write, f"  [green]{m['name']}: launched[/]"
                            )
                        else:
                            self.app.call_from_thread(
                                log.write, f"  [red]{m['name']}: FAILED (rc={rc}) {launch_err}[/]"
                            )
                    # Phase 3: Launch base station if selected
                    if _bs_machine and _bs_session:
                        self.app.call_from_thread(
                            log.write, "[bold]Launching base station...[/]"
                        )
                        # Stop fleet zenohd so BS can bind port 7447
                        if _fleet_zenoh["proc"]:
                            self.app.call_from_thread(
                                log.write, "  [dim]Stopping fleet zenohd (base station will take over)...[/]"
                            )
                            _stop_fleet_zenohd()

                        out_dir = f"{output_root}/{experiment}"
                        q_output = _quote_path(out_dir)
                        platform = _bs_machine.get("platform_id", _bs_machine["name"])
                        bs_cmd = (
                            f"cd ~/dcist_ws && source install/setup.zsh && "
                            f"src/awesome_dcist_t4/dcist_launch_system/bin/run-adt4 "
                            f"{shlex.quote(_bs_session)} -n {shlex.quote(_bs_machine['name'])} "
                            f"-c {shlex.quote(platform)} -o {q_output} -y "
                            f"--tmuxp-args \"-d\""
                        )
                        self.app.call_from_thread(
                            log.write, f"  [dim][{_bs_machine['user']}@{_bs_machine['ip']}] {bs_cmd}[/]"
                        )
                        rc, out, err = ssh_cmd(_bs_machine["user"], _bs_machine["ip"], bs_cmd, timeout=30)
                        if rc == 0:
                            self.app.call_from_thread(
                                log.write, f"  [green]{_bs_machine['name']}: base station launched[/]"
                            )
                            # Restart fleet zenohd on port+1
                            zenoh_port = topo.get("zenoh", {}).get("port", 7447)
                            zok, zmsg = _start_fleet_zenohd(force_port=zenoh_port + 1)
                            self.app.call_from_thread(
                                log.write, f"  [dim]Fleet zenohd: {zmsg}[/]" if zok else f"  [yellow]Fleet zenohd: {zmsg}[/]"
                            )
                        else:
                            self.app.call_from_thread(
                                log.write, f"  [red]{_bs_machine['name']}: FAILED (rc={rc}) {err}[/]"
                            )

                    self.app.call_from_thread(log.write, "[bold]Launch sequence complete.[/]")
                finally:
                    self._launching = False

            threading.Thread(target=do_launch, daemon=True).start()

    # ---- Monitor Screen ----

    class MonitorScreen(ModalScreen):
        BINDINGS = [
            Binding("escape", "dismiss", "Back", priority=True),
            Binding("r", "refresh", "Refresh", priority=True),
            Binding("n", "refresh_nodes", "Node Status", priority=True),
            Binding("k", "stop_save", "Stop & Save", priority=True),
            Binding("enter", "drill_down", "Details", priority=True),
            Binding("v", "gen_rviz", "RViz Config", priority=True),
            Binding("z", "check_zenoh", "Zenoh/Radio", priority=True),
            Binding("f3", "check_silvus_routes", "Check Routes [F3]", priority=True),
            Binding("f4", "add_silvus_routes", "Add Routes [F4]", priority=True),
            Binding("f2", "start_zenohd", "Start Zenohd [F2]", priority=True),
        ]

        def compose(self) -> ComposeResult:
            yield VerticalScroll(
                Label("[bold]Fleet Monitor[/]"),
                Rule(),
                Label("[bold]System Status[/] (r=refresh)"),
                Static(id="monitor_table"),
                Rule(),
                Label("[bold]Node Readiness[/] (n=refresh, Enter=details, k=stop & save)"),
                DataTable(id="node_summary_table"),
                Rule(),
                RichLog(id="monitor_log", highlight=True, markup=True, max_lines=30),
            )
            yield Footer()

        def _build_status_table(self, results=None):
            """Build a Rich Table from system status results."""
            t = Table(box=None, expand=True, pad_edge=False)
            t.add_column("Machine", no_wrap=True, min_width=8)
            t.add_column("Tmux", no_wrap=False, max_width=20)
            t.add_column("ROS2", no_wrap=True, max_width=5)
            t.add_column("Load 1/5/15m", no_wrap=False, max_width=16)
            t.add_column("Mem", no_wrap=True, max_width=12)
            t.add_column("GPU", no_wrap=False, max_width=18)
            t.add_column("Disk", no_wrap=False, max_width=20)
            t.add_column("Bat", no_wrap=True, max_width=18)
            t.add_column("Radio", no_wrap=True, max_width=14)
            if results:
                for m, st in sorted(results, key=lambda x: x[0]["name"]):
                    if isinstance(st, Exception):
                        t.add_row(m["name"], str(st), "", "", "", "", "", "", "")
                    else:
                        t.add_row(
                            m["name"],
                            st["tmux_sessions"],
                            st["ros2_procs"],
                            st["load"],
                            st.get("mem", "N/A"),
                            st.get("gpu", "N/A"),
                            st["disk"],
                            st.get("battery", "N/A"),
                            st.get("radio", "N/A"),
                        )
            return t

        def on_mount(self):
            self._node_status = {}  # robot_name -> [node dicts]

            # Render empty table initially
            widget = self.query_one("#monitor_table", Static)
            widget.update(self._build_status_table())

            node_table = self.query_one("#node_summary_table", DataTable)
            node_table.add_column("Robot", key="robot")
            node_table.add_column("Readiness", key="readiness")
            node_table.add_column("Nodes", key="nodes")
            node_table.add_column("Issues", key="issues")
            node_table.cursor_type = "row"

            self.action_refresh()
            self.action_refresh_nodes()

        def action_refresh(self):
            log = self.query_one("#monitor_log", RichLog)
            log.write("[dim]Refreshing system status...[/]")

            def do_fetch():
                machines = [m for m in runtime_config.values() if m.get("online", False)]
                sys_radios = topo.get("silvus_radios", {}).get("radios", {})
                silvus_ips = [r["mgmt_ip"] for r in sys_radios.values() if "mgmt_ip" in r]

                def fetch(m):
                    return get_remote_status(m["user"], m["ip"], silvus_ips=silvus_ips)

                return run_parallel(fetch, machines)

            def on_done(results):
                widget = self.query_one("#monitor_table", Static)
                widget.update(self._build_status_table(results))
                log.write("[green]System status updated.[/]")

            def bg():
                results = do_fetch()
                self.app.call_from_thread(on_done, results)

            threading.Thread(target=bg, daemon=True).start()

        def action_refresh_nodes(self):
            log = self.query_one("#monitor_log", RichLog)
            if not shutil.which("ros2"):
                log.write("[yellow]ROS 2 not found — node status unavailable. System status and SSH features still work.[/]")
                return
            log.write("[dim]Fetching ROS node status via topic (8s timeout)...[/]")

            def do_fetch():
                # Quick check: is the topic advertised?
                try:
                    topic_check = subprocess.run(
                        ["ros2", "topic", "list"],
                        capture_output=True, text=True, timeout=5,
                    )
                    topics = topic_check.stdout.strip().split("\n") if topic_check.returncode == 0 else []
                    has_topic = any("/global/ros_system_monitor/table_in" in t for t in topics)
                except Exception:
                    has_topic = False
                    topics = []

                status = get_ros_node_status(timeout=8)
                return status, has_topic, len(topics)

            def on_done(result):
                status, has_topic, n_topics = result
                self._node_status = status
                node_table = self.query_one("#node_summary_table", DataTable)
                node_table.clear()

                if not status:
                    zenohd_running = (
                        (_fleet_zenoh["proc"] and _fleet_zenoh["proc"].poll() is None)
                        or subprocess.run(
                            ["pgrep", "-f", "rmw_zenohd"],
                            capture_output=True,
                        ).returncode == 0
                    )
                    if not zenohd_running:
                        log.write("[red]No node status — zenohd is not running. Launch a base station session or restart fleet-adt4 with ROS sourced.[/]")
                    elif not has_topic:
                        log.write(f"[yellow]No node status — topic /global/ros_system_monitor/table_in not found ({n_topics} topics visible). Is ros_system_monitor running on robots?[/]")
                    else:
                        online = [m["name"] for m in runtime_config.values() if m.get("online") and m.get("role") == "robot"]
                        if online:
                            log.write(f"[yellow]No node status received — topic exists but no data within 8s. Robots: {', '.join(online)}[/]")
                        else:
                            log.write("[yellow]No node status — zenohd is running but no robots are online.[/]")
                    return

                for robot_name in sorted(status):
                    nodes = status[robot_name]
                    color, label = compute_robot_readiness(nodes)
                    n_total = len(nodes)
                    n_nominal = sum(1 for n in nodes if n["status"] == _STATUS_NOMINAL)

                    # Collect issue summaries
                    issues = []
                    for n in nodes:
                        if n["status"] != _STATUS_NOMINAL:
                            sname = _STATUS_NAMES.get(n["status"], "?")
                            issues.append(f"{n['nickname']}={sname}")
                    issue_str = ", ".join(issues) if issues else "none"

                    readiness_str = f"[{color}]{label}[/{color}]"
                    node_table.add_row(
                        robot_name,
                        readiness_str,
                        f"{n_nominal}/{n_total}",
                        issue_str,
                        key=robot_name,
                    )

                # Check for loop closures in hydra_multi
                for robot_name, nodes in status.items():
                    for n in nodes:
                        if "hydra_multi" in n["nickname"] and n["notes"]:
                            log.write(f"[cyan]{robot_name}/{n['nickname']}:[/] {n['notes']}")

                log.write("[green]Node status updated.[/]")

            def bg():
                result = do_fetch()
                self.app.call_from_thread(on_done, result)

            threading.Thread(target=bg, daemon=True).start()

        def action_drill_down(self):
            """Show detailed per-node status for the selected robot."""
            node_table = self.query_one("#node_summary_table", DataTable)
            log = self.query_one("#monitor_log", RichLog)

            try:
                from textual.coordinate import Coordinate
                row_idx = node_table.cursor_coordinate.row
                robot_name = str(node_table.get_cell_at(Coordinate(row_idx, 0)))
            except Exception:
                log.write("[red]No robot selected in node summary table.[/]")
                return

            nodes = self._node_status.get(robot_name)
            if not nodes:
                log.write(f"[red]No node data for {robot_name}.[/]")
                return

            log.write(f"\n[bold]Node details for {robot_name}:[/]")
            for n in sorted(nodes, key=lambda x: x["nickname"]):
                status = n["status"]
                color = _STATUS_COLORS.get(status, "white")
                sname = _STATUS_NAMES.get(status, "?")
                notes = f" — {n['notes']}" if n["notes"] else ""
                log.write(f"  [{color}]{sname:8s}[/{color}]  {n['nickname']}{notes}")

        def action_stop_save(self):
            """Send shutdown signal to all online robots via tmux."""
            log = self.query_one("#monitor_log", RichLog)
            online_machines = [m for m in runtime_config.values() if m.get("online", False)]
            if not online_machines:
                log.write("[red]No online machines to stop.[/]")
                return

            names = ", ".join(m["name"] for m in sorted(online_machines, key=lambda x: x["name"]))
            log.write(f"[yellow]Sending Stop & Save to: {names}[/]")

            def do_stop():
                def stop_one(m):
                    ok, msg = send_tmux_keys(m["user"], m["ip"])
                    return m["name"], ok, msg
                return run_parallel(stop_one, online_machines)

            def on_done(results):
                for item, result in sorted(results, key=lambda x: x[0]["name"]):
                    if isinstance(result, Exception):
                        log.write(f"  [red]{item['name']}: {result}[/]")
                    else:
                        mname, ok, msg = result
                        color = "green" if ok else "red"
                        log.write(f"  [{color}]{mname}: {msg}[/{color}]")
                log.write("[bold]Stop & Save complete.[/]")

            def bg():
                results = do_stop()
                self.app.call_from_thread(on_done, results)

            threading.Thread(target=bg, daemon=True).start()

        def action_gen_rviz(self):
            """Generate a namespaced rviz config for a robot."""
            log = self.query_one("#monitor_log", RichLog)
            # Use the first robot in runtime_config as default
            robots = [m for m in sorted(runtime_config) if runtime_config[m].get("role") == "robot"]
            if not robots:
                log.write("[red]No robots in config.[/]")
                return

            # Generate for each robot
            for robot_name in robots:
                mconf = runtime_config[robot_name]
                platform_id = mconf.get("platform_id", robot_name)
                out_path = generate_namespaced_rviz(robot_name)
                log.write(f"  Generated [cyan]{out_path}[/] for {robot_name}")

            log.write(f"[bold]RViz configs generated.[/] Launch with:")
            log.write(f"  [dim]rviz2 -d /tmp/dcist_<robot>.rviz[/]")

        def action_check_zenoh(self):
            """Check zenoh port reachability + Silvus radio link quality for all machines."""
            log = self.query_one("#monitor_log", RichLog)
            log.write("[dim]Checking zenoh connectivity and radio link quality...[/]")

            zenoh_conf = topo.get("zenoh", {})
            zenoh_port = zenoh_conf.get("port", 7447)

            def do_check():
                machines = list(runtime_config.values())
                sys_radios = topo.get("silvus_radios", {}).get("radios", {})
                silvus_mgmt_ips = [r["mgmt_ip"] for r in sys_radios.values() if "mgmt_ip" in r]

                results = []
                for m in machines:
                    ip = m["ip"]
                    zenoh_ok = check_zenoh_port(ip, port=zenoh_port)

                    radio = None
                    if m.get("online") and silvus_mgmt_ips:
                        try:
                            radio = get_silvus_link_quality(m["user"], ip, silvus_mgmt_ips)
                        except Exception:
                            pass

                    results.append((m, zenoh_ok, radio))
                return results

            def on_done(results):
                log.write(f"\n[bold]Zenoh Port {zenoh_port} Reachability:[/]")
                for m, zenoh_ok, _ in sorted(results, key=lambda x: x[0]["name"]):
                    color = "green" if zenoh_ok else "red"
                    status = "OPEN" if zenoh_ok else "CLOSED"
                    log.write(f"  [{color}]{m['name']:12s} {m['ip']:18s} {status}[/{color}]")

                has_radio = any(r for _, _, r in results if r)
                if has_radio:
                    log.write(f"\n[bold]Silvus Radio Link Quality:[/]")
                    for m, _, radio in sorted(results, key=lambda x: x[0]["name"]):
                        if not radio:
                            continue
                        if "error" in radio:
                            log.write(f"  [red]{m['name']:12s} {radio['error']}[/]")
                        elif "raw" in radio:
                            log.write(f"  [dim]{m['name']:12s} {radio['raw']}[/]")
                        else:
                            bat = radio.get("battery", "?")
                            mesh = radio.get("mesh_nodes", "?")
                            neighbors = radio.get("neighbor_count", "?")
                            rssi = radio.get("rssi", "N/A")
                            snr = radio.get("snr", "N/A")
                            log.write(
                                f"  [cyan]{m['name']:12s}[/] "
                                f"Bat:{bat}% Mesh:{mesh} Neighbors:{neighbors} "
                                f"RSSI:{rssi} SNR:{snr}"
                            )
                log.write("[bold]Zenoh/radio check complete.[/]")

            def bg():
                results = do_check()
                self.app.call_from_thread(on_done, results)

            threading.Thread(target=bg, daemon=True).start()

        def action_check_silvus_routes(self):
            """Check if Silvus management route exists on all machines + locally."""
            log = self.query_one("#monitor_log", RichLog)
            log.write("[dim]Checking Silvus management routes...[/]")

            mgmt_subnet = topo.get("silvus_radios", {}).get("mgmt_subnet", "172.20.0.0/16")

            def do_check():
                results = []
                # Check local machine first
                local_info = check_silvus_route(mgmt_subnet=mgmt_subnet)
                results.append(("LOCAL", None, local_info))

                # Check all online machines
                machines = [m for m in runtime_config.values() if m.get("online")]
                for m in machines:
                    try:
                        info = check_silvus_route(m["user"], m["ip"], mgmt_subnet)
                        results.append((m["name"], m, info))
                    except Exception as e:
                        results.append((m["name"], m, {"has_route": False, "interface": None, "silvus_iface": None, "error": str(e)}))
                return results

            def on_done(results):
                log.write(f"\n[bold]Silvus Management Route ({mgmt_subnet}):[/]")
                for name, m, info in sorted(results, key=lambda x: x[0]):
                    iface = info.get("silvus_iface") or "—"
                    if info.get("has_route"):
                        route = info.get("route_info", "OK")
                        log.write(f"  [green]{name:12s}[/] iface={iface}  [green]ROUTE OK[/] ({route})")
                    elif info.get("silvus_iface"):
                        log.write(f"  [red]{name:12s}[/] iface={iface}  [red]NO ROUTE[/] — press F4 to add")
                    else:
                        log.write(f"  [dim]{name:12s}[/] [dim]No Silvus interface (no 192.168.100.x address)[/]")

            def bg():
                results = do_check()
                self.app.call_from_thread(on_done, results)

            threading.Thread(target=bg, daemon=True).start()

        def action_add_silvus_routes(self):
            """Add Silvus management route on all machines that are missing it (requires sudo)."""
            log = self.query_one("#monitor_log", RichLog)
            log.write("[yellow]Adding Silvus management routes (requires sudo)...[/]")

            mgmt_subnet = topo.get("silvus_radios", {}).get("mgmt_subnet", "172.20.0.0/16")

            def do_add():
                results = []
                # Local machine
                ok, msg = add_silvus_route(mgmt_subnet=mgmt_subnet)
                results.append(("LOCAL", ok, msg))

                # All online machines
                machines = [m for m in runtime_config.values() if m.get("online")]
                for m in machines:
                    try:
                        ok, msg = add_silvus_route(m["user"], m["ip"], mgmt_subnet)
                        results.append((m["name"], ok, msg))
                    except Exception as e:
                        results.append((m["name"], False, str(e)))
                return results

            def on_done(results):
                log.write(f"\n[bold]Silvus Route Setup ({mgmt_subnet}):[/]")
                for name, ok, msg in sorted(results, key=lambda x: x[0]):
                    color = "green" if ok else "red"
                    log.write(f"  [{color}]{name:12s}: {msg}[/{color}]")
                log.write("[bold]Route setup complete.[/]")

            def bg():
                results = do_add()
                self.app.call_from_thread(on_done, results)

            threading.Thread(target=bg, daemon=True).start()

        def action_start_zenohd(self):
            """Manually start/restart the fleet-managed zenohd."""
            log = self.query_one("#monitor_log", RichLog)

            # Check if a system zenohd is already running (e.g. from base station tmux)
            system_zenohd = subprocess.run(
                ["pgrep", "-f", "rmw_zenohd"], capture_output=True
            ).returncode == 0
            fleet_zenohd = _fleet_zenoh["proc"] and _fleet_zenoh["proc"].poll() is None

            if system_zenohd and not fleet_zenohd:
                log.write("[yellow]A zenohd is already running (likely from base station tmux). "
                          "Starting fleet zenohd on port+1 to avoid conflict...[/]")
                zenoh_port = topo.get("zenoh", {}).get("port", 7447)
                ok, msg = _start_fleet_zenohd(force_port=zenoh_port + 1)
            elif fleet_zenohd:
                log.write("[dim]Fleet zenohd already running. Stopping and restarting...[/]")
                _stop_fleet_zenohd()
                ok, msg = _start_fleet_zenohd()
            else:
                ok, msg = _start_fleet_zenohd()

            color = "green" if ok else "red"
            log.write(f"[{color}]Fleet zenohd: {msg}[/{color}]")
            if ok:
                log.write("[dim]Press 'n' to refresh node status.[/]")

    # ---- Zenoh Screen ----

    class ZenohScreen(ModalScreen):
        BINDINGS = [
            Binding("escape", "dismiss", "Back", priority=True),
            Binding("d", "deploy_all", "Deploy All", priority=True),
            Binding("p", "preview", "Preview", priority=True),
        ]

        def compose(self) -> ComposeResult:
            yield Vertical(
                Label("[bold]Zenoh Config Manager[/]"),
                Label(f"[dim]Network: {active_network} — Base stations connect to robots (star topology)[/]"),
                Rule(),
                DataTable(id="zenoh_table"),
                Rule(),
                RichLog(id="zenoh_log", highlight=True, markup=True, max_lines=30),
            )
            yield Footer()

        def on_mount(self):
            self._endpoints = {}  # machine_name -> list of endpoint strings
            table = self.query_one("#zenoh_table", DataTable)
            table.add_column("Machine", key="machine")
            table.add_column("Role", key="role")
            table.add_column("Connect Endpoints", key="connect")
            table.add_column("Status", key="status")
            table.cursor_type = "row"
            self._build_table()

        def _build_table(self):
            table = self.query_one("#zenoh_table", DataTable)
            table.clear()
            log = self.query_one("#zenoh_log", RichLog)
            self._endpoints = {}

            for mname in sorted(runtime_config):
                mconf = runtime_config[mname]
                try:
                    endpoints = generate_zenoh_endpoints(topo, active_network, mname)
                    self._endpoints[mname] = endpoints
                except KeyError:
                    table.add_row(mname, mconf["role"], "?", "No address", key=mname)
                    continue

                n = len(endpoints)
                connect_str = f"{n} robot(s)" if n else "none (listen only)"
                table.add_row(mname, mconf["role"], connect_str, "Ready", key=mname)

            log.write(f"[dim]Computed endpoints for {len(self._endpoints)} machine(s). Press [bold]d[/] to deploy, [bold]p[/] to preview.[/]")

        def action_preview(self):
            table = self.query_one("#zenoh_table", DataTable)
            log = self.query_one("#zenoh_log", RichLog)
            try:
                from textual.coordinate import Coordinate
                row_idx = table.cursor_coordinate.row
                mname = str(table.get_cell_at(Coordinate(row_idx, 0)))
            except Exception:
                log.write("[red]No machine selected.[/]")
                return

            endpoints = self._endpoints.get(mname)
            if endpoints is None:
                log.write(f"[red]No config for {mname}.[/]")
                return

            log.write(f"\n[bold]Connect endpoints for {mname}:[/]")
            if endpoints:
                for ep in endpoints:
                    log.write(f"  {ep}")
            else:
                log.write("  (none — listen only)")

        def action_deploy_all(self):
            log = self.query_one("#zenoh_log", RichLog)
            if not self._endpoints:
                log.write("[red]No machines to deploy to.[/]")
                return

            log.write("[dim]Deploying configs (updating connect.endpoints in existing JSON5)...[/]")

            def do_deploy():
                results = []
                machines_to_deploy = []
                for mname, endpoints in self._endpoints.items():
                    mconf = runtime_config.get(mname)
                    if not mconf or not mconf.get("online"):
                        results.append((mname, False, "Offline"))
                        continue
                    machines_to_deploy.append((mname, mconf, endpoints))

                def deploy_one(item):
                    mname, mconf, endpoints = item
                    ok, msg = deploy_zenoh_config(mconf["user"], mconf["ip"], endpoints)
                    return mname, ok, msg

                parallel_results = run_parallel(deploy_one, machines_to_deploy)
                for item, result in parallel_results:
                    if isinstance(result, Exception):
                        results.append((item[0], False, str(result)))
                    else:
                        results.append(result)

                return results

            def on_done(results):
                table = self.query_one("#zenoh_table", DataTable)
                for mname, ok, msg in sorted(results):
                    status = f"[green]{msg}[/]" if ok else f"[red]{msg}[/]"
                    log.write(f"  {mname}: {status}")
                    # Update table status column
                    try:
                        table.update_cell(mname, "status", msg)
                    except Exception:
                        pass
                deployed = sum(1 for _, ok, _ in results if ok)
                log.write(f"[bold]Deployed {deployed}/{len(results)} configs.[/]")

            def bg():
                results = do_deploy()
                self.app.call_from_thread(on_done, results)

            threading.Thread(target=bg, daemon=True).start()

    # ---- Mission Screen ----

    class MissionScreen(ModalScreen):
        """Guided workflow for Mapping or Relocalize missions."""

        BINDINGS = [
            Binding("escape", "dismiss", "Back", priority=True),
            Binding("f5", "go", "Run Step [F5]", priority=True),
            Binding("f6", "auto_run", "Auto-Run [F6]", priority=True),
            Binding("r", "refresh_priors", "Refresh Priors", priority=True),
        ]

        def action_dismiss(self):
            self._loop_poll_stop = True
            self.dismiss()

        DEFAULT_CSS = """
        MissionScreen #mission_log {
            min-height: 10;
        }
        MissionScreen #prior_tree {
            min-height: 8;
            max-height: 16;
        }
        """

        # Step status indicators
        _STEP_PENDING = "[dim]\u25cb[/]"   # ○
        _STEP_RUNNING = "[yellow]\u25cf[/]" # ●
        _STEP_DONE = "[green]\u2714[/]"     # ✔
        _STEP_FAIL = "[red]\u2718[/]"       # ✘
        _STEP_MANUAL = "[cyan]\u270b[/]"    # ✋

        def __init__(self, mode="mapping"):
            super().__init__()
            self._mode = mode
            self._current_step = 0
            self._auto = False
            self._running = False
            self._running_since = 0  # monotonic timestamp

            if mode == "mapping":
                self._steps = [
                    {"name": "Deploy zenoh configs", "auto": True},
                    {"name": "Launch robots", "auto": True},
                    {"name": "Wait for all nodes green", "auto": True},
                    {"name": "Generate rviz config", "auto": True},
                    {"name": "Launch base station", "auto": True},
                    {"name": "Monitor mapping (manual)", "auto": False},
                    {"name": "Stop & Save maps (manual)", "auto": False},
                ]
            else:  # relocalize
                self._steps = [
                    {"name": "Deploy zenoh configs", "auto": True},
                    {"name": "Transfer prior maps", "auto": True},
                    {"name": "Launch robots (relocalize)", "auto": True},
                    {"name": "Wait for all nodes green", "auto": True},
                    {"name": "Generate rviz config", "auto": True},
                    {"name": "Launch base station", "auto": True},
                    {"name": "Move robots for loop closures (manual)", "auto": False},
                    {"name": "Ready for commands", "auto": True},
                ]
            self._rviz_config_path = None  # set by _step_gen_rviz
            self._confirmed = False
            self._loop_poll_stop = False  # flag to stop loop closure polling

            for step in self._steps:
                step["status"] = "pending"

        def compose(self) -> ComposeResult:
            mode_label = "Mapping" if self._mode == "mapping" else "Relocalize"
            yield VerticalScroll(
                Label(f"[bold]Mission: {mode_label}[/]"),
                Label("[dim]F5=run next step, F6=auto-run, escape=back[/]"),
                Rule(),
                Label("Select robots:"),
                SelectionList(
                    *[
                        (m["name"], m["name"], m.get("online", False))
                        for m in runtime_config.values()
                        if m["role"] == "robot"
                    ],
                    id="mission_robots",
                ),
                Rule(),
                Label("Robot session:"),
                Input(placeholder="Filter sessions...", id="mission_session_search"),
                SelectionList(
                    *(
                        [(s, s) for s in sorted(f.stem for f in _TMUX_DIR.glob("*.yaml"))]
                        if _TMUX_DIR.exists() else []
                    ),
                    id="mission_session_select",
                ),
                Rule(),
                Label("Base station:"),
                SelectionList(
                    *[
                        (m["name"], f"{m['name']} (local)" if m["ip"] in _local_ips else m["name"], m.get("online", False) or m["ip"] in _local_ips)
                        for m in runtime_config.values()
                        if m["role"] == "base_station"
                    ],
                    id="mission_base_station",
                ),
                Label("Base station session:"),
                SelectionList(
                    *(
                        [(s, s) for s in sorted(
                            f.stem for f in _TMUX_DIR.glob("base_station*.yaml")
                        )]
                        if _TMUX_DIR.exists() else []
                    ),
                    id="mission_bs_session",
                ),
                Rule(),
                Label("Experiment name:"),
                Input(placeholder="date_description", id="mission_experiment"),
                Rule(),
                *(
                    [
                        PriorMapSelector(id="mission_prior_selector"),
                        Rule(),
                    ] if self._mode == "relocalize" else []
                ),
                Vertical(id="mission_steps"),
                Rule(),
                RichLog(id="mission_log", highlight=True, markup=True, max_lines=50),
            )
            yield Footer()

        def on_mount(self):
            self._rebuild_steps()
            # Populate session list
            if _TMUX_DIR.exists():
                sessions = sorted([f.stem for f in _TMUX_DIR.glob("*.yaml")])
                sel = self.query_one("#mission_session_select", SelectionList)
                sel.clear_options()
                for s in sessions:
                    sel.add_option((s, s))

        def on_input_changed(self, event: Input.Changed):
            if event.input.id == "mission_session_search":
                query = event.value.strip()
                sessions = sorted(
                    [f.stem for f in _TMUX_DIR.glob("*.yaml")]
                ) if _TMUX_DIR.exists() else []
                sel = self.query_one("#mission_session_select", SelectionList)
                sel.clear_options()
                for s in sessions:
                    if _fuzzy_match(query, s):
                        sel.add_option((s, s))

        def _rebuild_steps(self):
            area = self.query_one("#mission_steps", Vertical)
            area.remove_children()
            for i, step in enumerate(self._steps):
                status = step["status"]
                if status == "pending":
                    icon = self._STEP_PENDING
                elif status == "running":
                    icon = self._STEP_RUNNING
                elif status == "done":
                    icon = self._STEP_DONE
                elif status == "failed":
                    icon = self._STEP_FAIL
                elif status == "manual":
                    icon = self._STEP_MANUAL
                else:
                    icon = self._STEP_PENDING

                auto_tag = "[AUTO]" if step["auto"] else "[MANUAL]"
                current = " [bold]<<[/]" if i == self._current_step else ""
                area.mount(Label(f"  {icon} {i+1}. {step['name']} {auto_tag}{current}"))

        def _get_robots(self):
            sel = self.query_one("#mission_robots", SelectionList)
            return [
                runtime_config[name]
                for name in sel.selected
                if name in runtime_config
            ]

        def _get_session(self):
            sel = self.query_one("#mission_session_select", SelectionList)
            selected = list(sel.selected)
            return selected[0] if selected else ""

        def _tlog(self, log, msg):
            """Thread-safe log write via call_from_thread."""
            self.app.call_from_thread(log.write, msg)

        def _set_step_status(self, idx, status):
            self._steps[idx]["status"] = status
            self.app.call_from_thread(self._rebuild_steps)

        def _show_confirmation(self, then_auto=False):
            """Validate selections and show a confirmation summary."""
            log = self.query_one("#mission_log", RichLog)
            robots = self._get_robots()
            robot_names = [m["name"] for m in robots]
            session = self._get_session()
            bs = self._get_base_station()
            bs_session = self._get_bs_session()
            try:
                experiment = self.query_one("#mission_experiment", Input).value.strip()
            except Exception:
                experiment = ""

            # Validate required fields
            problems = []
            if not robot_names:
                problems.append("No robots selected")
            if not session:
                problems.append("No robot session selected")
            if not bs:
                problems.append("No base station selected")
            if not bs_session:
                problems.append("No base station session selected")
            if not experiment:
                problems.append("No experiment name")
            
            if self._mode == "relocalize":
                try:
                    prior, prior_source = self.query_one("#mission_prior_selector", PriorMapSelector).get_prior_map()
                except Exception:
                    prior = ""
                    prior_source = None
                if not prior:
                    problems.append("No prior map specified")
            else:
                prior = ""
                prior_source = None

            if problems:
                for p in problems:
                    log.write(f"[red]  \u2718 {p}[/]")
                return

            mode_label = "Mapping" if self._mode == "mapping" else "Relocalize"
            bs_name = bs["name"] if bs else "—"
            offline = [n for n in robot_names if not runtime_config.get(n, {}).get("online")]
            log.write(f"[bold]── Mission Summary ──[/]")
            log.write(f"  Mode:              [cyan]{mode_label}[/]")
            log.write(f"  Robots:            [cyan]{', '.join(robot_names)}[/]")
            if offline:
                log.write(f"  [yellow]  Warning: {', '.join(offline)} not confirmed online[/]")
            log.write(f"  Robot session:     [cyan]{session}[/]")
            log.write(f"  Base station:      [cyan]{bs_name}[/]")
            log.write(f"  BS session:        [cyan]{bs_session}[/]")
            log.write(f"  Experiment:        [cyan]{experiment}[/]")
            if self._mode == "relocalize":
                log.write(f"  Prior map:         [cyan]{prior}[/]")

            self._mission_params = {
                "robots": robots,
                "session": session,
                "bs": bs,
                "bs_session": bs_session,
                "experiment": experiment,
                "prior": prior,
                "prior_source": prior_source
            }

            log.write(f"[bold]Press {'F6' if then_auto else 'F5'} again to confirm and start.[/]")
            self._confirmed = True
            self._pending_auto = then_auto

        def action_go(self):
            """Run the next step."""
            log = self.query_one("#mission_log", RichLog)
            try:
                if self._running:
                    # Auto-reset if stuck for >5 minutes
                    import time as _time
                    elapsed = _time.monotonic() - self._running_since if self._running_since else 0
                    if self._running_since and elapsed > 60:
                        log.write("[yellow]Previous step timed out (>60s). Resetting...[/]")
                        self._running = False
                    else:
                        log.write(f"[yellow]A step is still running (step {self._current_step + 1}, {elapsed:.0f}s). Please wait...[/]")
                        return
                if self._current_step >= len(self._steps):
                    log.write("[green]All steps complete![/]")
                    return
                if not self._confirmed:
                    self._show_confirmation(then_auto=False)
                    return
                self._auto = False
                self._run_current_step()
            except Exception as e:
                import traceback
                log.write(f"[red]Error: {e}\n{traceback.format_exc()}[/red]")

        def action_auto_run(self):
            """Auto-run all automated steps, pausing at manual ones."""
            if self._running:
                return
            if not self._confirmed:
                self._show_confirmation(then_auto=True)
                return
            self._auto = True
            self._run_current_step()

        def _run_current_step(self):
            if self._current_step >= len(self._steps):
                return

            step = self._steps[self._current_step]
            log = self.query_one("#mission_log", RichLog)

            # If it's a manual step, mark it and stop auto-run
            if not step["auto"]:
                step["status"] = "manual"
                self._rebuild_steps()
                log.write(f"[cyan]Step {self._current_step + 1}: {step['name']} — waiting for operator[/]")
                log.write("[dim]Press F5 when done to advance to the next step.[/]")

                # Start loop closure polling for relocalize manual step
                if "loop closures" in step["name"] and shutil.which("ros2"):
                    self._start_loop_closure_polling(log)

                self._current_step += 1
                return

            import time as _time
            try:
                self._running = True
                self._running_since = _time.monotonic()
                step["status"] = "running"
                self._rebuild_steps()

                # SNAPSHOT DOM VALUES BEFORE THREAD STARTS
                robots = self._mission_params.get("robots", [])
                log.write(f"[dim]Starting step with {len(robots)} robot(s)...[/]")
            except Exception as exc:
                # Reset running flag if setup fails before thread starts
                self._running = False
                self._running_since = 0
                import traceback
                log.write(f"[red]Failed to start step: {exc}\n{traceback.format_exc()}[/red]")
                return

            def run_step():
                try:
                    success = self._execute_step(self._current_step, log, robots)
                    if success:
                        self._set_step_status(self._current_step, "done")
                        self._current_step += 1
                        # Auto-advance if in auto mode
                        if self._auto and self._current_step < len(self._steps):
                            self.app.call_from_thread(self._run_current_step)
                        elif self._current_step >= len(self._steps):
                            self._tlog(log, "[bold green]Mission complete![/]")
                    else:
                        self._set_step_status(self._current_step, "failed")
                        self._tlog(
                            log,
                            f"[bold red]Step {self._current_step + 1} failed. Fix and press F5 to retry.[/]"
                        )
                except Exception as exc:
                    import traceback
                    self._tlog(log, f"[red]Step crashed: {exc}\n{traceback.format_exc()}[/red]")
                    self._set_step_status(self._current_step, "failed")
                finally:
                    self._running = False
                    self._running_since = 0

            threading.Thread(target=run_step, daemon=True).start()

        def _execute_step(self, step_idx, log, robots):
            """Execute a single step. Returns True on success."""
            step_name = self._steps[step_idx]["name"]
            self._tlog(log, f"[bold]Step {step_idx + 1}: {step_name}[/]")

            # Steps that require robots selected
            needs_robots = (
                "Deploy zenoh configs",
                "Transfer prior maps",
                "Launch robots",
                "Wait for all nodes green",
                "Generate rviz config",
            )
            if any(step_name.startswith(n) for n in needs_robots) and not robots:
                self._tlog(log, "[red]No robots selected.[/]")
                return False

            if step_name == "Deploy zenoh configs":
                return self._step_deploy_zenoh(robots, log)
            elif step_name == "Transfer prior maps":
                return self._step_transfer_priors(robots, log)
            elif step_name.startswith("Launch robots"):
                return self._step_launch(robots, log)
            elif step_name == "Wait for all nodes green":
                return self._step_wait_nodes(robots, log)
            elif step_name == "Generate rviz config":
                return self._step_gen_rviz(robots, log)
            elif step_name == "Launch base station":
                return self._step_launch_base_station(robots, log)
            elif step_name == "Ready for commands":
                self._tlog(
                    log,
                    "[bold green]System ready for language commands![/]\n"
                    "  Use the NLU panel in rviz or heracles_agents chatdsg."
                )
                return True
            else:
                self._tlog(log, f"[yellow]Unknown step: {step_name}[/]")
                return True  # skip unknown

        def _step_deploy_zenoh(self, robots, log):
            """Deploy zenoh configs to the selected base station and robots only.

            Only the base station gets connect endpoints (to the selected robots).
            Robots get empty endpoints (they just listen — star topology).
            """
            bs = self._mission_params.get("bs")

            # Build the target list: selected robots + selected base station
            targets = list(robots)
            if bs:
                # Add BS — ssh_cmd handles local detection transparently
                targets.append(bs)

            if not targets:
                self._tlog(log, "[red]No machines to deploy to.[/]")
                return False

            robot_names = [m["name"] for m in robots]
            names = ", ".join(m["name"] for m in targets)
            self._tlog(log, f"  Deploying to: {names}")
            self._tlog(log, f"  [dim]BS connects to robots: {', '.join(robot_names)}[/]")

            success = True
            for i, m in enumerate(targets):
                try:
                    self._tlog(log, f"  [{i+1}/{len(targets)}] {m['name']}...")
                    endpoints = generate_zenoh_endpoints(
                        topo, active_network, m["name"],
                        robot_filter=robot_names,
                    )
                    self._tlog(log, f"    [dim]{len(endpoints)} endpoint(s)[/]")
                    ok, msg = deploy_zenoh_config(m["user"], m["ip"], endpoints)
                    color = "green" if ok else "red"
                    self._tlog(log, f"    [{color}]{msg}[/{color}]")
                    if not ok:
                        success = False
                except KeyError:
                    self._tlog(log, f"  [dim]{m['name']}: no address on {active_network}[/]")
            return success

        def action_refresh_priors(self):
            if self._mode == "relocalize":
                log = self.query_one("#mission_log", RichLog)
                self.query_one("#mission_prior_selector", PriorMapSelector).refresh_priors(log)

        def _step_transfer_priors(self, robots, log):
            """Transfer prior maps to all robots."""
            prior_path = self._mission_params.get("prior", "")
            source = self._mission_params.get("prior_source")
            if not prior_path:
                self._tlog(log, "[red]No prior map specified.[/]")
                return False

            self._tlog(log, f"  [dim]Prior map: {prior_path}[/]")

            if not source:
                for m in runtime_config.values():
                    if not m.get("online"):
                        continue
                    q_path = _quote_path(prior_path)
                    rc, out, _ = ssh_cmd(m["user"], m["ip"], f"test -d {q_path} && echo OK", timeout=5)
                    if "OK" in out:
                        source = m["name"]
                        self._tlog(log, f"  [dim]Found prior on {source}[/]")
                        break

            if not source:
                self._tlog(log, "[red]Prior map not found on any machine.[/]")
                return False

            src_conf = runtime_config.get(source)
            if not src_conf:
                self._tlog(log, f"[red]Source {source} not in config.[/]")
                return False

            exp_name = pathlib.Path(prior_path).name
            dest_name = f"prior_{exp_name}"
            dest_path = f"{output_root}/{dest_name}"

            success = True
            for m in robots:
                if m["name"] == source:
                    continue
                self._tlog(log, f"  Transferring to {m['name']}...")
                ok, method, msg = rsync_transfer(
                    src_conf["user"], src_conf["ip"], prior_path,
                    m["user"], m["ip"], dest_path,
                    relay=False, exclude=["recorded_data/"],
                )
                if ok:
                    self._tlog(log, f"  [green]{m['name']}: transferred ({method})[/]")
                else:
                    self._tlog(log, f"  [red]{m['name']}: FAILED: {msg}[/]")
                    success = False
            return success

        def _step_launch(self, robots, log):
            """Launch run-adt4 on all selected robots."""
            session = self._mission_params.get("session", "")
            experiment = self._mission_params.get("experiment", "")
            if not session:
                self._tlog(log, "[red]No session selected.[/]")
                return False
            if not experiment:
                self._tlog(log, "[red]No experiment name.[/]")
                return False

            # Build prior map flag from snapshot
            prior_flag = ""
            if self._mode == "relocalize":
                prior_path = self._mission_params.get("prior", "")
                if prior_path:
                    exp_name = pathlib.Path(prior_path).name
                    dest_name = f"prior_{exp_name}"
                    prior_flag = f" -p {_quote_path(output_root + '/' + dest_name)}"

            # Skip session conflict check from background thread (it uses call_from_thread)
            # Sessions were already validated during confirmation

            success = True
            for m in robots:
                out_dir = f"{output_root}/{experiment}"
                rc, out, _ = ssh_cmd(m["user"], m["ip"], f"test -d {_quote_path(out_dir)} && echo EXISTS", timeout=5)
                if "EXISTS" in out:
                    self._tlog(log, f"  [yellow]{m['name']}: {out_dir} already exists, skipping[/]")
                    continue

                platform = m.get("platform_id", m["name"])
                q_output = _quote_path(out_dir)
                cmd = (
                    f"cd ~/dcist_ws && source install/setup.zsh && "
                    f"src/awesome_dcist_t4/dcist_launch_system/bin/run-adt4 "
                    f"{shlex.quote(session)} -n {shlex.quote(m['name'])} "
                    f"-c {shlex.quote(platform)} -o {q_output} -y{prior_flag} "
                    f"--tmuxp-args \"-d\""
                )
                self._tlog(log, f"  [dim][{m['user']}@{m['ip']}] {cmd}[/]")
                self._tlog(log, f"  Launching on {m['name']}...")
                rc, out, err = ssh_cmd(m["user"], m["ip"], cmd, timeout=30)
                if rc == 0:
                    self._tlog(log, f"  [green]{m['name']}: launched[/]")
                else:
                    self._tlog(log, f"  [red]{m['name']}: FAILED (rc={rc}) {err}[/]")
                    success = False
            return success

        def _step_wait_nodes(self, robots, log):
            """Poll node status until all robots are green/yellow."""
            if not shutil.which("ros2"):
                self._tlog(log, "[yellow]ROS 2 not found — skipping node wait. Check nodes manually once base station is running.[/]")
                return True

            import time
            robot_names = {m["name"] for m in robots}
            max_wait = 120  # seconds
            start = time.time()

            self._tlog(log, f"  [dim]Waiting up to {max_wait}s for nodes to come online...[/]")

            while time.time() - start < max_wait:
                status = get_ros_node_status(timeout=8)
                if not status:
                    time.sleep(5)
                    continue

                all_ready = True
                for rname in robot_names:
                    nodes = status.get(rname, [])
                    if not nodes:
                        all_ready = False
                        continue
                    color, label = compute_robot_readiness(nodes)
                    if color == "red":
                        all_ready = False

                if all_ready and any(status.get(r) for r in robot_names):
                    for rname in sorted(robot_names):
                        nodes = status.get(rname, [])
                        if nodes:
                            color, label = compute_robot_readiness(nodes)
                            self._tlog(log, f"  [{color}]{rname}: {label}[/{color}]")
                    self._tlog(log, "[green]All robots ready![/]")
                    return True

                elapsed = int(time.time() - start)
                self._tlog(log, f"  [dim]Waiting... ({elapsed}s)[/]")
                time.sleep(5)

            # Timeout
            self._tlog(log, f"[yellow]Timeout after {max_wait}s. Some nodes may not be ready.[/]")
            status = get_ros_node_status(timeout=8)
            for rname in sorted(robot_names):
                nodes = status.get(rname, [])
                if nodes:
                    color, label = compute_robot_readiness(nodes)
                    self._tlog(log, f"  [{color}]{rname}: {label}[/{color}]")
                    for n in nodes:
                        if n["status"] != _STATUS_NOMINAL:
                            sname = _STATUS_NAMES.get(n["status"], "?")
                            scolor = _STATUS_COLORS.get(n["status"], "white")
                            self._tlog(log, f"    [{scolor}]{n['nickname']}: {sname}[/{scolor}]")
                else:
                    self._tlog(log, f"  [red]{rname}: no status data[/]")
            return True

        def _step_gen_rviz(self, robots, log):
            """Generate namespaced rviz configs."""
            paths = []
            for m in robots:
                out_path = generate_namespaced_rviz(m["name"])
                paths.append(out_path)
                self._tlog(log, f"  Generated [cyan]{out_path}[/]")
            if paths:
                self._rviz_config_path = paths[0]
            return True

        def _start_loop_closure_polling(self, log):
            """Poll ROS node status every 10s and report loop closure counts."""
            import re as _re
            self._loop_poll_stop = False
            robot_names = {m["name"] for m in self._mission_params.get("robots", [])}
            LC_THRESHOLD = 5

            def _poll():
                import time
                while not self._loop_poll_stop:
                    try:
                        status = get_ros_node_status(timeout=8)
                        if not status:
                            time.sleep(10)
                            continue
                        parts = []
                        all_ready = True
                        for rname in sorted(robot_names):
                            nodes = status.get(rname, [])
                            for n in nodes:
                                if "hydra_multi" not in n.get("nickname", ""):
                                    continue
                                notes = n.get("notes", "")
                                match = _re.search(r"(\d+)\s*(?:loop\s*closures?|lc)", notes, _re.IGNORECASE)
                                if match:
                                    count = int(match.group(1))
                                    color = "green" if count >= LC_THRESHOLD else "yellow"
                                    parts.append(f"[{color}]{rname}: {count}/{LC_THRESHOLD} LC[/{color}]")
                                    if count < LC_THRESHOLD:
                                        all_ready = False
                                elif notes:
                                    parts.append(f"[dim]{rname}: {notes}[/]")
                                    all_ready = False
                                else:
                                    all_ready = False
                        if parts:
                            self._tlog(log, "  Loop closures: " + ", ".join(parts))
                        if all_ready and parts:
                            self._tlog(log, "[bold green]All robots have enough loop closures! Press F5 to continue.[/]")
                            break
                    except Exception:
                        pass
                    time.sleep(10)

            threading.Thread(target=_poll, daemon=True).start()

        def _get_base_station(self):
            sel = self.query_one("#mission_base_station", SelectionList)
            selected = list(sel.selected)
            if not selected:
                return None
            return runtime_config.get(selected[0])

        def _get_bs_session(self):
            sel = self.query_one("#mission_bs_session", SelectionList)
            selected = list(sel.selected)
            return selected[0] if selected else ""

        def _step_launch_base_station(self, robots, log):
            """Launch run-adt4 on the base station with the generated rviz config."""
            # Terminate fleet-managed zenohd so the base station session's zenohd
            # can bind the same port without conflict
            if _fleet_zenoh["proc"]:
                self._tlog(log, "  [dim]Stopping fleet zenohd (base station will take over)...[/]")
                _stop_fleet_zenohd()

            # Use snapshotted params instead of DOM queries
            bs = self._mission_params.get("bs")
            if not bs:
                self._tlog(log, "[red]No base station selected.[/]")
                return False

            bs_session = self._mission_params.get("bs_session", "")
            if not bs_session:
                self._tlog(log, "[red]No base station session selected.[/]")
                return False

            experiment = self._mission_params.get("experiment", "")
            if not experiment:
                self._tlog(log, "[red]No experiment name.[/]")
                return False

            out_dir = f"{output_root}/{experiment}"
            q_output = _quote_path(out_dir)
            platform = bs.get("platform_id", bs["name"])

            # Skip session conflict check from background thread (deadlock risk)

            rviz_flag = ""
            if self._rviz_config_path:
                rviz_flag = f" --rviz-config {shlex.quote(self._rviz_config_path)}"

            cmd = (
                f"cd ~/dcist_ws && source install/setup.zsh && "
                f"src/awesome_dcist_t4/dcist_launch_system/bin/run-adt4 "
                f"{shlex.quote(bs_session)} -n {shlex.quote(bs['name'])} "
                f"-c {shlex.quote(platform)} -o {q_output} -y{rviz_flag} "
                f"--tmuxp-args \"-d\""
            )

            self._tlog(log, f"  [dim][{bs['user']}@{bs['ip']}] {cmd}[/]")
            self._tlog(log, f"  Launching base station on {bs['name']}...")
            rc, out, err = ssh_cmd(bs["user"], bs["ip"], cmd, timeout=30)
            if rc == 0:
                self._tlog(log, f"  [green]{bs['name']}: base station launched[/]")
                # Restart fleet zenohd on port+1 so ROS monitoring still works
                zenoh_port = topo.get("zenoh", {}).get("port", 7447)
                zok, zmsg = _start_fleet_zenohd(force_port=zenoh_port + 1)
                self._tlog(log, f"  [dim]Fleet zenohd: {zmsg}[/]" if zok else f"  [yellow]Fleet zenohd: {zmsg}[/]")
                return True
            else:
                self._tlog(log, f"  [red]{bs['name']}: FAILED (rc={rc}) {err}[/]")
                return False

    # ---- Main App ----

    class FleetApp(App):
        CSS = """
        Screen {
            background: $surface;
        }
        #status_table {
            height: auto;
            max-height: 50%;
        }
        #log {
            height: auto;
            min-height: 5;
        }
        ModalScreen {
            align: center middle;
        }
        """

        BINDINGS = [
            Binding("s", "refresh_status", "Recheck"),
            Binding("l", "show_launch", "Launch"),
            Binding("b", "show_maps", "Browse Maps"),
            Binding("c", "show_config", "Config"),
            Binding("o", "show_monitor", "Monitor"),
            Binding("z", "show_zenoh", "Zenoh"),
            Binding("q", "quit", "Quit"),
        ]

        def compose(self) -> ComposeResult:
            yield Header()
            yield Vertical(
                Label(f"[bold]fleet-adt4[/]  network: [cyan]{active_network}[/]"),
                Rule(),
                DataTable(id="status_table"),
                Rule(),
                RichLog(id="log", highlight=True, markup=True, max_lines=100),
            )
            yield Footer()

        def on_mount(self):
            self.title = "fleet-adt4"
            self.sub_title = f"network: {active_network}"
            table = self.query_one("#status_table", DataTable)
            table.add_column("Machine", key="machine")
            table.add_column("Role", key="role")
            table.add_column("Platform", key="platform")
            table.add_column("IP", key="ip")
            table.add_column("Ping", key="ping")
            table.add_column("SSH", key="ssh")
            table.add_column("Status", key="status")
            self.action_refresh_status()

        def action_refresh_status(self):
            log = self.query_one("#log", RichLog)
            log.write("[dim]Checking fleet connectivity (ping + SSH)...[/]")

            def do_check():
                machines = list(runtime_config.values())
                reachable, unreachable = filter_reachable(machines)
                return reachable + unreachable

            def on_done(all_machines):
                table = self.query_one("#status_table", DataTable)
                table.clear()
                n_online = 0
                for m in sorted(all_machines, key=lambda x: x["name"]):
                    ping_str = "OK" if m.get("ping") else "FAIL"
                    ssh_str = "OK" if m.get("ssh") else "FAIL"
                    if m.get("online"):
                        status_str = "ONLINE"
                        n_online += 1
                    elif m.get("ping"):
                        status_str = "NO SSH"
                    else:
                        status_str = "OFFLINE"
                    table.add_row(
                        m["name"],
                        m["role"],
                        runtime_config[m["name"]].get("platform_id", "---"),
                        m["ip"],
                        ping_str,
                        ssh_str,
                        status_str,
                    )
                    # Update runtime_config with reachability
                    runtime_config[m["name"]].update({
                        "ping": m.get("ping", False),
                        "ssh": m.get("ssh", False),
                        "online": m.get("online", False),
                    })
                log.write(f"[green]{n_online}/{len(all_machines)} machines online.[/]")

            def bg():
                results = do_check()
                self.app.call_from_thread(on_done, results)

            log = self.query_one("#log", RichLog)
            threading.Thread(target=bg, daemon=True).start()

        def action_show_maps(self):
            self.push_screen(MapsScreen())

        def action_show_launch(self):
            self.push_screen(LaunchScreen())

        def action_show_config(self):
            self.push_screen(ConfigScreen())

        def action_show_monitor(self):
            self.push_screen(MonitorScreen())

        def action_show_zenoh(self):
            self.push_screen(ZenohScreen())

        def action_show_mission(self):
            """Prompt for mission mode, then launch the MissionScreen."""

            class ModeSelectScreen(ModalScreen):
                BINDINGS = [
                    Binding("escape", "dismiss", "Back", priority=True),
                    Binding("m", "select_mapping", "Mapping", priority=True),
                    Binding("r", "select_relocalize", "Relocalize", priority=True),
                ]

                def compose(self) -> ComposeResult:
                    yield VerticalScroll(
                        Label("[bold]Select Mission Mode[/]"),
                        Rule(),
                        Label("[dim]m=Mapping  r=Relocalize  escape=Back[/]"),
                    )
                    yield Footer()

                def action_select_mapping(self):
                    self.dismiss("mapping")

                def action_select_relocalize(self):
                    self.dismiss("relocalize")

            def on_mode_selected(mode):
                if mode:
                    self.push_screen(MissionScreen(mode=mode))

            self.push_screen(ModeSelectScreen(), callback=on_mode_selected)

    # Auto-start zenohd if ROS 2 + rmw_zenoh_cpp are available and not already running.
    # Uses the bundled zenoh_router_template.json5 (copied from a fleet machine) as the
    # base config — preserves all ROS transport/timeout/routing settings. Patches only
    # connect.endpoints and listen port from the topology.
    _fleet_zenoh = {"proc": None, "config": None}  # mutable so closures can modify

    def _stop_fleet_zenohd():
        """Terminate the fleet-managed zenohd so the base station session can take over."""
        proc = _fleet_zenoh["proc"]
        if proc and proc.poll() is None:
            proc.terminate()
            try:
                proc.wait(timeout=5)
            except subprocess.TimeoutExpired:
                proc.kill()
                proc.wait(timeout=2)
            import time
            time.sleep(1)  # allow port to be released (TIME_WAIT)
            _fleet_zenoh["proc"] = None

    def _start_fleet_zenohd(force_port=None):
        """Start (or restart) the fleet-managed zenohd.

        If force_port is given, use that listen port instead of auto-detecting.
        Returns (True, message) if started, (False, reason) otherwise.
        """
        if not shutil.which("ros2"):
            return False, "ros2 not found on PATH — source your ROS workspace first"

        # Don't start if one is already running under our control
        if _fleet_zenoh["proc"] and _fleet_zenoh["proc"].poll() is None:
            return True, "already running"

        try:
            local_ips = _local_ips
            zenoh_conf = topo.get("zenoh", {})
            port = zenoh_conf.get("port", 7447)

            # Determine this machine's role from topology
            local_machine = None
            for m in runtime_config.values():
                if m["ip"] in local_ips:
                    local_machine = m
                    break

            # Build endpoints from topology
            if local_machine:
                endpoints = generate_zenoh_endpoints(
                    topo, active_network, local_machine["name"]
                )
                listen_port = force_port or port
            else:
                endpoints = [
                    f"tcp/{m['ip']}:{port}"
                    for m in runtime_config.values()
                    if m.get("role") == "base_station" and m.get("ip")
                ]
                listen_port = force_port or (port + 1)

            # Clean up previous config
            if _fleet_zenoh["config"]:
                try:
                    os.unlink(_fleet_zenoh["config"])
                except OSError:
                    pass
                _fleet_zenoh["config"] = None

            config_path = patch_zenoh_config_local(
                endpoints, listen_port=listen_port,
            )
            if not config_path:
                return False, "failed to patch zenoh config (template missing?)"

            _fleet_zenoh["config"] = config_path
            import tempfile
            stderr_log = tempfile.NamedTemporaryFile(
                mode="w", prefix="fleet_zenohd_", suffix=".log", delete=False
            )
            # Source the ROS workspace before running zenohd — fleet-adt4 may
            # have been started without full ROS env (e.g. ros2 on PATH via
            # .zshrc but workspace not sourced).
            shell_cmd = (
                f"source ~/dcist_ws/install/setup.zsh 2>/dev/null || "
                f"source ~/dcist_ws/install/setup.bash 2>/dev/null; "
                f"ZENOH_ROUTER_CONFIG_URI={shlex.quote(config_path)} "
                f"ros2 run rmw_zenoh_cpp rmw_zenohd"
            )
            _fleet_zenoh["proc"] = subprocess.Popen(
                ["bash", "-c", shell_cmd],
                stdout=subprocess.DEVNULL,
                stderr=stderr_log,
            )
            # Check it didn't die immediately
            import time
            time.sleep(1.0)
            if _fleet_zenoh["proc"].poll() is not None:
                rc = _fleet_zenoh["proc"].returncode
                _fleet_zenoh["proc"] = None
                stderr_log.close()
                try:
                    with open(stderr_log.name) as f:
                        err_output = f.read().strip()[-500:]  # last 500 chars
                except Exception:
                    err_output = ""
                detail = f"\n  stderr: {err_output}" if err_output else ""
                return False, f"rmw_zenohd exited immediately (rc={rc}){detail}\n  config: {config_path}"
            stderr_log.close()
            return True, f"started on port {listen_port} with {len(endpoints)} endpoint(s)"
        except Exception as e:
            return False, f"error: {e}"

    try:
        already_running = subprocess.run(
            ["pgrep", "-f", "rmw_zenohd"],
            capture_output=True,
        ).returncode == 0

        if not already_running:
            _start_fleet_zenohd()
    except Exception:
        pass  # non-critical — monitor will just lack ROS topic data

    try:
        app = FleetApp()
        app.run()
    finally:
        _stop_fleet_zenohd()
        if _fleet_zenoh["config"]:
            try:
                os.unlink(_fleet_zenoh["config"])
            except OSError:
                pass


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

if __name__ == "__main__":
    cli()
