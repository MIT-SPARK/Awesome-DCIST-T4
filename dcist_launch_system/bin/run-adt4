#!/usr/bin/env python3

import atexit
import enum
import os
import pathlib
import readline
import shlex
import shutil
import subprocess
import sys
import tempfile
from dataclasses import dataclass, field
from typing import Optional

import click
import rich
import yaml
from rich.panel import Panel
from rich.syntax import Syntax
from rich.table import Table

ADT4_VARS = [
    "ADT4_ROBOT_NAME",
    "ADT4_PLATFORM_ID",
    "ADT4_OUTPUT_DIR",
    "ADT4_PRIOR_MAP",
    "ADT4_SIM_TIME",
    "ADT4_RVIZ_CONFIG",
]


class PlatformType(enum.Enum):
    """Enum for platform type."""

    SPOT = "spot"
    PHOENIX = "phoenix"
    BASE_STATION = "base_station"


@dataclass
class SessionInfo:
    """Struct for session config."""

    robot_name: str
    output_path: pathlib.Path
    platform_id: str = ""
    sim_time: bool = False
    bag: Optional[pathlib.Path] = None
    bag_delay: float = 5.0
    trajectory: Optional[pathlib.Path] = None
    trajectory_args: list[str] = field(default_factory=list)
    record: Optional[str] = None

    @property
    def platform_type(self) -> PlatformType:
        """The platform type inferred from the platform ID."""
        if self.platform_id in ["smaug", "topaz", "apollo"]:
            return PlatformType.SPOT

        if self.platform_id == "base_station":
            return PlatformType.BASE_STATION

        if self.platform_id == "phoenix":
            return PlatformType.PHOENIX

        click.secho("Platform ID '{self.platform_id}' is unknown!", fg="red")
        sys.exit("invalid platform")


def _ws_path():
    return pathlib.Path(__file__).absolute().parent.parent


def _get_important_experiments():
    manifest_path = _ws_path() / "config_generation" / "experiment_manifest.yaml"
    if not manifest_path.exists():
        click.secho(f"Failed to load manifest from {manifest_path}!", fg="red")

    with manifest_path.open("r") as fin:
        contents = yaml.safe_load(fin)

    return contents.get("important_variants", [])


def _resolve_prior_map(prior_map):
    if prior_map == "???":
        # this only triggers when someone wants to be prompted for a prior map
        # and doesn't want to add it via command line.
        prior_map = input("prior map? ")
        if not prior_map:
            click.secho("No prior map entered! Continuing...", fg="yellow")

    if prior_map:
        prior_map = pathlib.Path(prior_map).expanduser().absolute()
        if not prior_map.exists():
            click.secho(f"Invalid prior map: '{prior_map}'!", fg="red")
            sys.exit("invalid prior map")

    return prior_map


def _show_options(choices, message=None):
    table = rich.table.Table(
        title=message, box=None, show_header=False, title_style="white bold"
    )
    table.add_column("Number", justify="right", style="cyan")
    table.add_column("Name", justify="left")
    for i, x in enumerate(choices):
        table.add_row(f"({i + 1})", x)

    rich.print(table)


def _resolve_session_path(session_path):
    tmux_ws_path = _ws_path() / "tmux" / "autogenerated"
    tmux_files = sorted([x for x in tmux_ws_path.glob("*.yaml")])
    if session_path is None:
        important_names = _get_important_experiments()
        if important_names:
            choice_files = [tmux_ws_path / f"{x}.yaml" for x in important_names]
        else:
            choice_files = tmux_files

        choices = [x.stem for x in choice_files]
        if important_names:
            choices.append("Show all...")

        _show_options(choices)
        idx = click.prompt("What session do you want to load?", default=len(choices))
        if important_names and idx == len(choices):
            choice_files = tmux_files
            _show_options([x.stem for x in choice_files])
            idx = click.prompt("What session do you want to load?", default=1)

        if idx <= 0 or idx > len(choice_files):
            click.secho(f"Invalid session choice: '{idx}'", fg="red")
            sys.exit("invalid session file")

        session_path = choice_files[idx - 1]

    session_path = pathlib.Path(session_path).expanduser()
    if not session_path.suffix:
        session_path = session_path.with_suffix(".yaml")

    session_path = tmux_ws_path / session_path
    if not session_path.exists():
        click.secho(f"Invalid tmuxp file: '{session_path}'!", fg="red")
        _show_options([x.stem for x in tmux_files], message="Available Session Files")
        sys.exit("invalid session file")

    return session_path


def _resolve_output_dir(output_dir, force):
    output_dir = pathlib.Path(output_dir).expanduser().absolute()
    if output_dir.exists():
        if not force:
            click.confirm(f"Output '{output_dir}' exists! Remove?", abort=True)

        click.secho(f"Clearing previous output: '{output_dir}'", fg="green")
        shutil.rmtree(output_dir)

    return output_dir


def _show_vars(env):
    table = Table(title="Environment Variables")
    table.add_column("Environment Variable", justify="left", style="cyan")
    table.add_column("Value", justify="right")
    for name in ADT4_VARS:
        table.add_row(name, env.get(name) or "---")

    rich.print(table)


def _run_session(session_path, env, tmuxp_args, dry_run):
    cmd = [shutil.which("tmuxp"), "load", str(session_path)]
    if tmuxp_args:
        cmd += shlex.split(tmuxp_args)

    if dry_run:
        click.secho(f"command: {' '.join(cmd)}", fg="green")
        return 0

    return subprocess.run(cmd, env=env).returncode


def _make_record_window(info: SessionInfo):
    record_name = info.platform_type.value if info.record == "???" else info.record
    topic_dir = _ws_path() / "recording"
    topic_path = topic_dir / f"{record_name}_topics.txt"
    if not topic_path.exists():
        click.secho(f"Invalid topic file '{topic_path}'!", fg="red")
        avail = [x.stem for x in topic_dir.glob("*_topics.txt")]
        _show_options(avail, message="Available Topic Files")
        sys.exit("invalid record topic file")

    click.secho(f"Recording topics from '{topic_path}'", fg="green")
    output_path = info.output_path / "recorded_data"
    cmd = f"ros2 run dcist_launch_system record_topics {output_path} {topic_path}"
    window_config = {
        "layout": "tiled",
        "panes": [cmd],
        "shell_command_before": "source ${ADT4_WS}/install/setup.zsh",
        "window_name": "recording",
    }
    return window_config


def _make_bag_window(info: SessionInfo):
    to_drop = [".*leg.*", ".*foot.*", ".*rail.*"]
    if info.trajectory:
        to_drop.append(".*odom.*")

    bag_args = ["--filter-tf", "-k", f"'.*{info.robot_name}.*'"]
    bag_args += ["--delay", str(info.bag_delay)]
    bag_args += [f"-f '{x}'" for x in to_drop]
    if info.sim_time:
        bag_args.append("--clock")

    window_config = {
        "layout": "tiled",
        "panes": [f"ros2 run ianvs play_rosbag {info.bag} {' '.join(bag_args)}"],
        "shell_command_before": "source ${ADT4_WS}/install/setup.zsh",
        "window_name": "play_rosbag",
    }
    if info.trajectory:
        is_spot = info.platform_id in ["topaz", "smaug", "apollo"]
        child_frame = f"{info.robot_name}/" + ("body" if is_spot else "base_link")
        cmd = ["ros2", "run", "ianvs", "csv_to_tf", f"{info.trajectory}"]
        cmd += ["--parent", f"{info.robot_name}/odom", "--child", child_frame]
        cmd += info.trajectory_args
        cmd += ["--ros-args", "-p", "use_sim_time:=true"]
        window_config["panes"].append(" ".join(cmd))

    return window_config


def _write_session_to_file(session_path, info: SessionInfo, fout, verbose=False):
    with session_path.open("r") as fin:
        contents = yaml.safe_load(fin.read())

    if info.bag:
        contents["windows"].append(_make_bag_window(info))

    if info.record:
        contents["windows"].append(_make_record_window(info))

    contents = yaml.dump(contents, width=300)
    fout.write(contents)
    fout.flush()

    if verbose:
        console = rich.console.Console()
        console.print(Panel(Syntax(contents, "yaml")))


@click.command()
@click.argument("session_path", type=click.Path(), default=None, required=False)
@click.option(
    "--tmuxp-args",
    default=None,
    help="args to forward to tmuxp",
)
@click.option(
    "--robot-name",
    "-n",
    envvar="ADT4_ROBOT_NAME",
    help="robot name to use",
)
@click.option(
    "--platform-id",
    "-c",
    envvar="ADT4_PLATFORM_ID",
    help="robot platform adt4 is running on",
)
@click.option(
    "--output-dir",
    "-o",
    envvar="ADT4_OUTPUT_DIR",
    type=click.Path(),
    help="output for adt4",
)
@click.option(
    "--prior-map",
    "-p",
    envvar="ADT4_PRIOR_MAP",
    help="prior map",
    is_flag=False,
    flag_value="???",
    type=click.Path(),
)
@click.option(
    "--sim-time",
    "-s",
    is_flag=True,
    help="use sim time",
)
@click.option(
    "--yes",
    "-y",
    is_flag=True,
    help="skip env variable check",
)
@click.option(
    "--force",
    "-f",
    is_flag=True,
    help="clear output if it exists",
)
@click.option(
    "--dry-run",
    "-d",
    is_flag=True,
    help="only show command",
)
@click.option(
    "--show-tmux",
    is_flag=True,
    help="show tmuxp contents before starting",
)
@click.option(
    "--bag",
    default=None,
    type=click.Path(exists=True),
    help="bag to run",
)
@click.option(
    "--bag-delay",
    default=5.0,
    help="bag playback delay",
)
@click.option(
    "--trajectory",
    "-t",
    default=None,
    type=click.Path(exists=True, dir_okay=False),
    help="trajectory to use when replaying bag",
)
@click.option(
    "--trajectory-args",
    default=None,
    help="args to forward to csv publisher",
)
@click.option(
    "--record",
    "-r",
    is_flag=False,
    flag_value="???",
)
@click.option(
    "--rviz-config",
    envvar="ADT4_RVIZ_CONFIG",
    type=click.Path(),
    default=None,
    help="custom rviz config file (overrides default dcist.rviz)",
)
def main(
    session_path,
    tmuxp_args,
    robot_name,
    platform_id,
    output_dir,
    prior_map,
    sim_time,
    yes,
    force,
    dry_run,
    show_tmux,
    bag,
    bag_delay,
    trajectory,
    trajectory_args,
    record,
    rviz_config,
):
    robot_name = robot_name or input("robot name to use? ")
    platform_id = platform_id or input("robot platform ID? ")
    output_dir = output_dir or input("output directory? ")

    prior_map = _resolve_prior_map(prior_map)
    session_path = _resolve_session_path(session_path)
    output_dir = _resolve_output_dir(output_dir, force)

    def _normalize_optional(opt_path: Optional[str]):
        return pathlib.Path(opt_path).expanduser().absolute() if opt_path else None

    env = os.environ.copy()
    env["ADT4_ROBOT_NAME"] = robot_name
    env["ADT4_PLATFORM_ID"] = platform_id
    env["ADT4_SIM_TIME"] = "true" if sim_time else "false"
    env["ADT4_OUTPUT_DIR"] = str(output_dir)
    if prior_map:
        env["ADT4_PRIOR_MAP"] = str(prior_map)
    if rviz_config:
        rviz_config = pathlib.Path(rviz_config).expanduser().absolute()
        if rviz_config.exists():
            env["ADT4_RVIZ_CONFIG"] = str(rviz_config)
        else:
            click.secho(
                f"Warning: rviz config not found: {rviz_config} — using default",
                fg="yellow",
            )

    click.secho(f"Loading {session_path}...")
    _show_vars(env)
    if not yes:
        click.confirm("Are the settings correct?", abort=True)

    info = SessionInfo(
        robot_name,
        output_dir,
        platform_id=platform_id,
        sim_time=sim_time,
        bag=_normalize_optional(bag),
        bag_delay=bag_delay,
        trajectory=_normalize_optional(trajectory),
        record=record,
    )
    if trajectory_args:
        info.trajectory_args = trajectory_args.split(" ")

    with tempfile.NamedTemporaryFile("w+", suffix=".yaml") as fout:
        _write_session_to_file(session_path, info, fout, verbose=dry_run or show_tmux)
        return _run_session(fout.name, env, tmuxp_args, dry_run)


if __name__ == "__main__":
    readline_history = pathlib.Path("~/.adt4_history").expanduser().absolute()
    if readline_history.exists():
        readline.read_history_file(str(readline_history))

    readline.set_history_length(1000)
    atexit.register(readline.write_history_file, readline_history)
    sys.exit(main())
