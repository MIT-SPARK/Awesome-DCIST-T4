# DCIST Docker Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored and will not be committed.

# ---- Display (for GUI apps like rviz2) ----
DISPLAY=:0

# ---- ROS 2 ----
RMW_IMPLEMENTATION=rmw_zenoh_cpp
ROS_DOMAIN_ID=0

# ---- Robot ----
ADT4_ROBOT_NAME=spot
ADT4_SIM_TIME=false
ADT4_OUTPUT_DIR=/root/dcist_ws/output
ADT4_PRIOR_MAP=

# ---- Boston Dynamics Spot ----
ADT4_BOSDYN_USERNAME=user
ADT4_BOSDYN_PASSWORD=pass
ADT4_BOSDYN_IP=192.168.80.3

# ---- API Keys ----
ADT4_OPENAI_API_KEY=
ADT4_DEEPGRAM_API_KEY=

# ---- Neo4j / Heracles Scene Graph Database ----
NEO4J_PASSWORD=neo4j_pw
ADT4_HERACLES_IP=localhost
ADT4_HERACLES_PORT=7687
ADT4_NEO4J_USERNAME=neo4j
ADT4_NEO4J_PASSWORD=neo4j_pw

# ---- NTRIP GPS Corrections ----
ADT4_NTRIP_HOST=
ADT4_NTRIP_PORT=2101
ADT4_NTRIP_MOUNTPOINT=
ADT4_NTRIP_USERNAME=
ADT4_NTRIP_PASSWORD=
